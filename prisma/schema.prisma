generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  zip       String?
  county    String?
  interests String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volunteerProfile           VolunteerProfile?
  commitments                Commitment[]
  submissions                Submission[]
  teamRoleAssignments        TeamRoleAssignment[]
  eventsOwned                CampaignEvent[]            @relation("EventOwner")
  tasksAssigned              CampaignTask[]             @relation("TaskAssignee")
  tasksCreated               CampaignTask[]             @relation("TaskCreator")
  volunteerAsksCreated       VolunteerAsk[]
  mediaIngestBatches         MediaIngestBatch[]
  ownedMediaAnnotationsOwned OwnedMediaAnnotation[]     @relation("AnnotationAuthor")
  /// Optional: voter roll row linked for campaign assistance (admin-approved intake).
  linkedVoterRecordId        String?
  linkedVoterRecord          VoterRecord?               @relation("UserVoterLink", fields: [linkedVoterRecordId], references: [id], onDelete: SetNull)
  volunteerSignupIntakes     SignupSheetDocument[]
  intakeMatchedEntries       SignupSheetEntry[]
  communicationThreads       CommunicationThread[]      @relation("ThreadPrimaryUser")
  threadsAssigned            CommunicationThread[]      @relation("ThreadAssignee")
  messagesSent               CommunicationMessage[]     @relation("MessageSentBy")
  queueItemsCreated          CommunicationActionQueue[] @relation("QueueCreatedBy")
  queueItemsTarget           CommunicationActionQueue[] @relation("QueueTargetUser")
  eventApprovalsSubmitted    EventApproval[]            @relation("ApprovalSubmittedBy")
  eventApprovalsDecided      EventApproval[]            @relation("ApprovalDecidedBy")
  eventStageChangesActed     EventStageChangeLog[]     @relation("EventStageChangeActor")
  eventsApprovedAsStaff      CampaignEvent[]            @relation("EventApprovedByStaff")
  calendarSourcesOwned       CalendarSource[]           @relation("CalendarSourceOwner")
  contactPreference          ContactPreference?
  communicationTemplatesCreated  CommunicationTemplate[]  @relation("TemplateAuthor")
  audienceSegmentsCreated        AudienceSegment[]      @relation("SegmentAuthor")
  communicationCampaignsCreated  CommunicationCampaign[]  @relation("CampaignAuthor")
  communicationCampaignsApproved CommunicationCampaign[] @relation("CampaignApprover")
  eventSignups                   EventSignup[]            @relation("UserEventSignups")
  communicationCampaignRecipients CommunicationCampaignRecipient[]
  /// Staff “human” Gmail rail (at most one linked mailbox; OAuth in `StaffGmailAccount`).
  staffGmailAccount            StaffGmailAccount?
}

enum EmailOptInStatus {
  UNKNOWN
  OPT_IN
  OPT_OUT
}

enum SmsOptInStatus {
  UNKNOWN
  OPT_IN
  OPT_OUT
}

/// Channel consent and third-party opt-out / suppression (Tier 1 comms workbench).
model ContactPreference {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  volunteerProfileId String?           @unique
  volunteerProfile   VolunteerProfile? @relation(fields: [volunteerProfileId], references: [id], onDelete: SetNull)

  /// Standalone thread (no User/VolunteerProfile) — e.g. SMS-only before resolution.
  communicationThreadId String?         @unique
  thread                CommunicationThread? @relation(fields: [communicationThreadId], references: [id], onDelete: Cascade)

  emailOptInStatus EmailOptInStatus @default(UNKNOWN)
  smsOptInStatus   SmsOptInStatus   @default(UNKNOWN)
  /// Marketing / bulk email: treat as do-not-mail when set.
  globalUnsubscribeAt DateTime?
  smsOptOutAt         DateTime?
  /// Raw SendGrid / Twilio / vendor signals for debugging and audits.
  sendgridSuppressionState Json?    @default("{}")
  twilioOptOutState        String?
  source                   String?
  notes                    String?  @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model VolunteerProfile {
  id                   String                     @id @default(cuid())
  userId               String                     @unique
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability         String?
  skills               String?
  leadershipInterest   Boolean                    @default(false)
  eventSignups         EventSignup[]
  communicationThreads CommunicationThread[]
  contactPreference   ContactPreference?
  queueAsTarget        CommunicationActionQueue[] @relation("QueueTargetVolunteer")
  communicationCampaignRecipients CommunicationCampaignRecipient[]
}

model Commitment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Submission {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String
  content        String   @db.Text
  structuredData Json?
  createdAt      DateTime @default(now())
}

model SearchChunk {
  id         String   @id @default(cuid())
  path       String
  title      String?
  chunkIndex Int
  content    String   @db.Text
  embedding  String   @db.Text
  createdAt  DateTime @default(now())

  @@unique([path, chunkIndex])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  payload   Json?
  path      String?
  sessionId String?
  createdAt DateTime @default(now())
}

// --- Website admin content board (Script 6) — public site CMS only ---

enum MediaKind {
  IMAGE
  VIDEO_EMBED
}

enum ContentCollection {
  STORY
  EDITORIAL
  EXPLAINER
}

enum BlogDisplayMode {
  SUMMARY_LINK
  EXCERPT_LINK
  INTERNAL_MIRROR_TODO
}

// --- Script 6.5 orchestrator enums (referenced by MediaAsset + inbound models) ---

enum ContentPlatform {
  SUBSTACK
  FACEBOOK
  INSTAGRAM
  YOUTUBE
}

enum PlatformConnectionStatus {
  INACTIVE
  CONFIGURED
  SYNCING
  ERROR
  OK
}

enum InboundSourceType {
  ARTICLE
  POST
  NOTE
  VIDEO
  REEL
  SHORT
  COMMENT
  PODCAST_EPISODE
  LIVE
  OTHER
}

enum InboundReviewStatus {
  PENDING
  REVIEWED
  FEATURED
  SUPPRESSED
  ARCHIVED
}

enum ContentRoutingDestination {
  NONE
  HOMEPAGE_RAIL
  PUBLIC_UPDATES
  BLOG
  STORIES_SEED
  EDITORIAL_SEED
  MEDIA_LIBRARY
  CAMPAIGN_BRIEF
}

enum ContentDecisionStatus {
  NEW
  REVIEWED
  FEATURED
  SUPPRESSED
  ARCHIVED
  ROUTED
}

/// Editorial / hub routing kind (Phase 1 content hub). Distinct from `InboundSourceType` (connector shape).
enum ContentHubKind {
  VIDEO
  STORY
  SPEECH
  ROAD_UPDATE
  EXPLAINER
  INTERVIEW
}

model MediaAsset {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  url              String
  kind             MediaKind        @default(IMAGE)
  width            Int?
  height           Int?
  alt              String?
  caption          String?
  tags             String[]         @default([])
  usageNotes       String?          @db.Text
  /// Optional lineage for connector-ingested media references (not necessarily uploaded here).
  originPlatform   ContentPlatform?
  originExternalId String?

  syncedPostHeroes SyncedPost[]          @relation("SyncedPostHeroMedia")
  contentOverrides ContentItemOverride[] @relation("ContentOverrideHeroMedia")
  inboundItems     InboundContentItem[]
}

/// Synced external blog posts (Substack via RSS). Not a second blog CMS — editorial control only.
model SyncedPost {
  id                  String              @id @default(cuid())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  lastSyncedAt        DateTime            @default(now())
  source              String              @default("substack")
  feedGuid            String?             @unique
  slug                String              @unique
  canonicalUrl        String
  title               String
  summary             String              @db.Text
  author              String?
  publishedAt         DateTime?
  featuredImageUrl    String?
  tagsFromFeed        String[]            @default([])
  localCategories     String[]            @default([])
  localTags           String[]            @default([])
  /// Issue / policy tags for hubs and future filters (editorial).
  issueTags           String[]            @default([])
  countySlug          String?
  countyFips          String?
  city                String?
  campaignPhase       String?
  contentSeries       String?
  playlistId          String?
  featuredWeight      Int?
  contentKind         ContentHubKind?
  /// Pin for homepage “From the Road” preview rail.
  featuredRoadPreview Boolean             @default(false)
  featured            Boolean             @default(false)
  hidden              Boolean             @default(false)
  teaserOverride      String?             @db.Text
  heroMediaId         String?
  heroMedia           MediaAsset?         @relation("SyncedPostHeroMedia", fields: [heroMediaId], references: [id], onDelete: SetNull)
  displayMode         BlogDisplayMode     @default(SUMMARY_LINK)
  showOnHomepage      Boolean             @default(false)
  showOnBlogLanding   Boolean             @default(true)
  rawItem             Json?
  inboundItem         InboundContentItem?

  @@index([publishedAt])
  @@index([hidden, featured])
  @@index([hidden, contentKind, publishedAt])
}

/// Page-scoped content blocks (hero, quote band, CTAs, etc.) — JSON payload by blockType.
model AdminContentBlock {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pageKey   String
  blockKey  String
  blockType String
  payload   Json
  label     String?

  @@unique([pageKey, blockKey])
  @@index([pageKey])
}

/// Singleton-style homepage composition + copy overrides (merged with `src/content/homepage.ts` defaults).
model HomepageConfig {
  id                             String   @id @default("default")
  hero                           Json?
  sectionOrder                   Json?
  heardItems                     Json?
  movementBeliefs                Json?
  pathwayCards                   Json?
  splitDemocracy                 Json?
  splitLabor                     Json?
  arkansasBand                   Json?
  quoteBand                      Json?
  finalCta                       Json?
  featuredStorySlugs             String[] @default([])
  featuredEditorialSlugs         String[] @default([])
  featuredSyncedPostSlugs        String[] @default([])
  featuredExplainerSlugs         String[] @default([])
  /// Curated `InboundContentItem.id` for homepage featured YouTube module (optional).
  featuredHomepageVideoInboundId String?
  updatedAt                      DateTime @updatedAt
}

/// Visibility / teaser / hero overrides for static story, editorial, explainer entries.
model ContentItemOverride {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  collection      ContentCollection
  slug            String
  hidden          Boolean           @default(false)
  featured        Boolean           @default(false)
  teaserOverride  String?           @db.Text
  summaryOverride String?           @db.Text
  heroMediaId     String?
  heroMedia       MediaAsset?       @relation("ContentOverrideHeroMedia", fields: [heroMediaId], references: [id], onDelete: SetNull)

  @@unique([collection, slug])
}

model SiteSettings {
  id                    String    @id @default("default")
  substackFeedUrl       String?   @db.Text
  canonicalSiteUrlNote  String?   @db.Text
  adminNotes            String?   @db.Text
  lastSubstackSyncAt    DateTime?
  lastSubstackSyncOk    Boolean?
  lastSubstackSyncError String?   @db.Text
  updatedAt             DateTime  @updatedAt
}

// --- Script 6.5 — Content orchestrator (intake / normalization / routing; not movement ops) ---

/// One row per connected surface (Substack feed, FB Page, IG account, YT channel).
model PlatformConnection {
  id                String                   @id @default(cuid())
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  platform          ContentPlatform          @unique
  status            PlatformConnectionStatus @default(INACTIVE)
  externalAccountId String?
  accountName       String?
  syncEnabled       Boolean                  @default(false)
  lastSyncedAt      DateTime?
  lastSyncError     String?                  @db.Text
  /// Non-secret hints: page id, channel id. Secrets stay in env (see docs).
  metadata          Json?
  metricSnapshots   PlatformMetricSnapshot[]

  @@index([platform, status])
}

/// Normalized inbound item from any connector. Substack posts also remain in `SyncedPost`.
model InboundContentItem {
  id                    String              @id @default(cuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  sourcePlatform        ContentPlatform
  sourceType            InboundSourceType   @default(ARTICLE)
  externalId            String
  authorName            String?
  title                 String?
  body                  String?             @db.Text
  excerpt               String?             @db.Text
  canonicalUrl          String?
  publishedAt           DateTime?
  mediaAssetId          String?
  mediaAsset            MediaAsset?         @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  tags                  String[]            @default([])
  issueTags             String[]            @default([])
  countySlug            String?
  countyFips            String?
  city                  String?
  campaignPhase         String?
  contentSeries         String?
  playlistId            String?
  featuredWeight        Int?
  contentKind           ContentHubKind?
  /// Quick hide from public hub pages without changing review workflow.
  siteHidden            Boolean             @default(false)
  metrics               Json?
  rawPayload            Json?
  syncTimestamp         DateTime            @default(now())
  reviewStatus          InboundReviewStatus @default(PENDING)
  /// Website distribution flags (human-approved; Substack /blog can still use `SyncedPost` independently).
  visibleOnUpdatesPage  Boolean             @default(false)
  visibleOnHomepageRail Boolean             @default(false)
  routeToBlog           Boolean             @default(false)
  storySeed             Boolean             @default(false)
  editorialSeed         Boolean             @default(false)
  /// Future outbound social — do not enable without audit (see docs).
  publishCandidate      Boolean             @default(false)
  syncedPostId          String?             @unique
  syncedPost            SyncedPost?         @relation(fields: [syncedPostId], references: [id], onDelete: SetNull)
  decisions             ContentDecision[]

  @@unique([sourcePlatform, externalId])
  @@index([sourcePlatform, reviewStatus])
  @@index([reviewStatus, visibleOnUpdatesPage])
  @@index([publishedAt])
  @@index([sourcePlatform, siteHidden, reviewStatus])
}

model ContentDecision {
  id            String                    @id @default(cuid())
  createdAt     DateTime                  @default(now())
  inboundItemId String
  inboundItem   InboundContentItem        @relation(fields: [inboundItemId], references: [id], onDelete: Cascade)
  status        ContentDecisionStatus
  destination   ContentRoutingDestination @default(NONE)
  notes         String?                   @db.Text
  editor        String?
}

model PlatformMetricSnapshot {
  id                   String             @id @default(cuid())
  capturedAt           DateTime           @default(now())
  platformConnectionId String
  connection           PlatformConnection @relation(fields: [platformConnectionId], references: [id], onDelete: Cascade)
  metrics              Json

  @@index([platformConnectionId, capturedAt])
}

// --- Campaign-owned media (uploads / DAM memory — distinct from `MediaAsset` URL register) ---

/// Image, video, audio, or document uploaded and stored in our storage layer.
enum OwnedMediaKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum OwnedMediaRole {
  SPEECH
  ROAD_CLIP
  PHOTO
  EVENT
  AD_CREATIVE
  B_ROLL
  GRAPHIC
  INTERVIEW
  OTHER
}

enum OwnedMediaSourceType {
  DIRECT_UPLOAD
  UPLOADED_CAMPAIGN
  IMPORT
  MIGRATED
  SUPPORTER_UPLOAD
  OTHER
}

/// Where the binary for this row lives. `SUPABASE` uses `storageKey` as the object key in the campaign bucket.
enum OwnedMediaStorageBackend {
  LOCAL_DISK
  SUPABASE
}

/// How geographic fields were set. Advisory until `needsGeoReview` is cleared in admin.
enum GeoMetadataSource {
  NONE
  EXIF
  MANUAL
  INFERRED
  REVERSE_GEO
}

enum OwnedMediaReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum TranscriptionJobStatus {
  NOT_REQUESTED
  QUEUED
  IN_PROGRESS
  SUCCEEDED
  FAILED
}

enum TranscriptSource {
  HUMAN
  ASR
  ASR_DRAFT
  IMPORT
  OTHER
}

enum TranscriptReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_EDIT
}

enum QuoteCandidateType {
  SUGGESTED
  EDITOR_PICK
  SOCIAL_CROP
  PRESS
  OTHER
}

enum QuoteReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OwnedMediaNoteType {
  DESCRIPTION
  PEOPLE
  LOCATION
  EVENT_CONTEXT
  MESSAGE_ANGLE
  CAPTION
  TRANSCRIPT_CORRECTION
  INTERNAL_NOTE
}

/// Canonical row for campaign-owned media (`OwnedMediaAsset` in app code; not renamed to `media_assets` in DB to avoid a breaking table rename).
model OwnedMediaAsset {
  id                      String                   @id @default(cuid())
  /// Storage object key. Local: `campaign-owned/...` · Supabase: `media/{year}/{month}/...` in the campaign bucket.
  storageKey              String                   @unique
  storageBackend          OwnedMediaStorageBackend @default(LOCAL_DISK)
  /// Optional public URL (Supabase public bucket URL, signed URL cache, or CDN). Local rows often use API route when null.
  publicUrl               String?
  /// Optional small preview in the same or sibling bucket path.
  thumbStorageKey         String?
  thumbPublicUrl          String?
  fileName                String
  fileSizeBytes           Int
  mimeType                String
  kind                    OwnedMediaKind
  role                    OwnedMediaRole           @default(OTHER)
  title                   String
  description             String?                  @db.Text
  /// Duration in seconds (video/audio) when known.
  durationSeconds         Int?
  width                   Int?
  height                  Int?
  /// EXIF/embedded “taken at” (device). Distinct from editorial `eventDate`.
  capturedAt              DateTime?
  eventDate               DateTime?
  /// GPS from EXIF when present (WGS84).
  gpsLat                  Float?
  gpsLng                  Float?
  geoSource               GeoMetadataSource        @default(NONE)
  /// 0–1 when inferred/reverse-mapped; null if unknown.
  geoConfidence           Float?
  /// True if county/city/geo should be confirmed before publishing to county pages.
  needsGeoReview          Boolean                  @default(false)
  countySlug              String?
  countyFips              String?
  city                    String?
  issueTags               String[]                 @default([])
  campaignPhase           String?
  contentSeries           String?
  speakerName             String?
  /// Raw EXIF / container / Nominatim audit tail (see `ingress` in JSON). AI or model suggestions use `enrichmentMetadata`, not this field.
  metadataJson            Json?
  sourceType              OwnedMediaSourceType     @default(DIRECT_UPLOAD)
  reviewStatus            OwnedMediaReviewStatus   @default(PENDING_REVIEW)
  isPublic                Boolean                  @default(false)
  /// For supporter-facing uploads later: explicit opt-in to campaign use.
  consentCampaignUse      Boolean?
  uploaderName            String?
  uploaderEmail           String?
  /// Staff-only operational notes (not necessarily public-facing).
  operatorNotes           String?                  @db.Text
  /// Draft social / press caption; distinct from structured annotation rows.
  captionDraft            String?                  @db.Text
  /// When EXIF `capturedAt` is wrong, override the “shot at” time for this asset.
  shootDateOverride       DateTime?
  /// Optional link to a scheduled campaign event (rally, canvass launch, etc.).
  linkedCampaignEventId   String?
  linkedCampaignEvent     CampaignEvent?           @relation("OwnedMediaCampaignEvent", fields: [linkedCampaignEventId], references: [id], onDelete: SetNull)
  /// Non-canonical: suggested tags, model hints, run timestamps. Never overwrites `OwnedMediaTranscript` text.
  enrichmentMetadata      Json?
  transcriptJobStatus     TranscriptionJobStatus   @default(NOT_REQUESTED)
  transcriptionLastError  String?                  @db.Text
  /// SHA-256 of file bytes; dedupes folder-ingest and future supporter uploads.
  ingestContentSha256     String?                  @unique
  /// Set by local folder watcher: original relative path (audit).
  localIngestRelativePath String?
  /// Optional bulk import session (folder / device ingest).
  mediaIngestBatchId      String?
  mediaIngestBatch        MediaIngestBatch?        @relation(fields: [mediaIngestBatchId], references: [id], onDelete: SetNull)
  createdBy               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  transcripts          OwnedMediaTranscript[]
  quoteCandidates      OwnedMediaQuoteCandidate[]
  annotations          OwnedMediaAnnotation[]
  signupSheetDocuments SignupSheetDocument[]

  @@index([countySlug, eventDate])
  @@index([countySlug, capturedAt])
  @@index([city, capturedAt])
  @@index([capturedAt])
  @@index([eventDate])
  @@index([reviewStatus])
  @@index([transcriptJobStatus])
  @@index([isPublic, reviewStatus])
  @@index([sourceType, reviewStatus])
  @@index([kind, capturedAt])
  @@index([needsGeoReview])
  @@index([gpsLat, gpsLng])
  @@index([linkedCampaignEventId])
  @@index([mediaIngestBatchId, reviewStatus])
}

model OwnedMediaAnnotation {
  id           String             @id @default(cuid())
  ownedMediaId String
  ownedMedia   OwnedMediaAsset    @relation(fields: [ownedMediaId], references: [id], onDelete: Cascade)
  authorUserId String?
  author       User?              @relation("AnnotationAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  noteType     OwnedMediaNoteType
  noteText     String             @db.Text
  tagsJson     Json?
  isSearchable Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([ownedMediaId, createdAt])
  @@index([ownedMediaId, noteType])
  @@index([isSearchable])
}

model OwnedMediaTranscript {
  id             String                 @id @default(cuid())
  ownedMediaId   String
  ownedMedia     OwnedMediaAsset        @relation(fields: [ownedMediaId], references: [id], onDelete: Cascade)
  transcriptText String                 @db.Text
  source         TranscriptSource
  language       String?
  confidence     Float?
  /// Raw ASR or provider segments (start/end, text). Kept for audit; not the canonical "human truth" if edited elsewhere.
  segmentsJson   Json?
  reviewStatus   TranscriptReviewStatus @default(PENDING)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  quoteCandidates OwnedMediaQuoteCandidate[]

  @@index([ownedMediaId, reviewStatus])
}

model OwnedMediaQuoteCandidate {
  id                 String                @id @default(cuid())
  ownedMediaId       String
  ownedMedia         OwnedMediaAsset       @relation(fields: [ownedMediaId], references: [id], onDelete: Cascade)
  transcriptId       String?
  transcript         OwnedMediaTranscript? @relation(fields: [transcriptId], references: [id], onDelete: SetNull)
  quoteText          String                @db.Text
  startSeconds       Float?
  endSeconds         Float?
  issueTags          String[]              @default([])
  countySlug         String?
  quoteType          QuoteCandidateType    @default(SUGGESTED)
  reviewStatus       QuoteReviewStatus     @default(PENDING)
  featuredWeight     Int?
  /// Non-canonical AI or heuristic suggestions; review gates approval.
  enrichmentMetadata Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([ownedMediaId, reviewStatus])
  @@index([transcriptId])
  @@index([countySlug])
}

// --- County command pages (public organizing intelligence + reviewable data) ---

enum CountyContentReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
}

enum ElectedJurisdiction {
  FEDERAL
  STATE
  COUNTY
  LOCAL
}

enum PublicDemographicsSource {
  CENSUS_ACS
  CENSUS_DECENNIAL
  MANUAL
  OTHER
}

/// Canonical US county for Arkansas campaign command pages (`/counties/[slug]`).
model County {
  id                 String   @id @default(cuid())
  slug               String   @unique
  fips               String   @unique
  displayName        String
  regionLabel        String?
  sortOrder          Int      @default(0)
  /// Hero kicker, e.g. "Central Arkansas"
  heroEyebrow        String?
  /// When null, UI uses a short generic line + region label.
  heroIntro          String?  @db.Text
  /// Who is leading here?
  leadName           String?
  leadTitle          String?
  leadBio            String?  @db.Text
  leadPhotoUrl       String?
  /// Curated `events` slugs for “upcoming on this page”
  featuredEventSlugs String[] @default([])
  showOnStatewideMap Boolean  @default(true)
  published          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  campaignStats CountyCampaignStats?
  demographics  CountyPublicDemographics?
  elected       CountyElectedOfficial[]

  countyVoterMetrics      CountyVoterMetrics[]
  voterRecords            VoterRecord[]
  voterSnapshotChanges    VoterSnapshotChange[]
  campaignEvents          CampaignEvent[]
  campaignTasks           CampaignTask[]
  volunteerAsks           VolunteerAsk[]
  eventSignups            EventSignup[]
  teamRoleAssignments     TeamRoleAssignment[]
  signupSheetEntries      SignupSheetEntry[]
  communicationThreads    CommunicationThread[]
  eventAnalyticsSnapshots EventAnalyticsSnapshot[]
  arkansasFestivalIngests ArkansasFestivalIngest[]

  @@index([published, sortOrder])
}

/// Campaign metrics — voter file fields structurally ready; null until pipeline syncs.
model CountyCampaignStats {
  id       String @id @default(cuid())
  countyId String @unique
  county   County @relation(fields: [countyId], references: [id], onDelete: Cascade)

  registrationGoal              Int?
  /// Actual new registrations since baseline (voter file); null = not yet synced
  newRegistrationsSinceBaseline Int?
  /// Baseline date for the “new since” number (campaign: 2025-11-25; mirrored from voter-file metrics)
  registrationBaselineDate      DateTime?
  volunteerTarget               Int?
  volunteerCount                Int?
  campaignVisits                Int?
  /// e.g. voter_file_nightly, manual_import
  dataPipelineSource            String?
  pipelineLastSyncAt            DateTime?
  pipelineError                 String?                   @db.Text
  reviewStatus                  CountyContentReviewStatus @default(PENDING_REVIEW)
  updatedAt                     DateTime                  @updatedAt
}

/// Trusted public / Census-style snapshot — always label source and review state.
model CountyPublicDemographics {
  id       String @id @default(cuid())
  countyId String @unique
  county   County @relation(fields: [countyId], references: [id], onDelete: Cascade)

  population               Int?
  votingAgePopulation      Int?
  medianHouseholdIncome    Int?
  povertyRatePercent       Float?
  bachelorsOrHigherPercent Float?
  laborEmploymentNote      String?                   @db.Text
  source                   PublicDemographicsSource  @default(CENSUS_ACS)
  sourceDetail             String?
  asOfYear                 Int?
  fetchedAt                DateTime?
  reviewStatus             CountyContentReviewStatus @default(PENDING_REVIEW)
  updatedAt                DateTime                  @updatedAt
}

/// Reviewable elected roster — can be hand-entered, imported, or later Google Civic.
model CountyElectedOfficial {
  id           String                    @id @default(cuid())
  countyId     String
  county       County                    @relation(fields: [countyId], references: [id], onDelete: Cascade)
  jurisdiction ElectedJurisdiction
  officeTitle  String
  name         String
  party        String?
  termEnd      String?
  sourceUrl    String?
  sourceLabel  String?
  externalId   String?
  sortOrder    Int                       @default(0)
  reviewStatus CountyContentReviewStatus @default(PENDING_REVIEW)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([countyId, jurisdiction, sortOrder])
}

// --- Voter file pipeline (SOS raw files → snapshots → per-county metrics → optional canonical voters) ---

enum VoterFileIngestStatus {
  RECEIVED
  PROCESSING
  COMPLETE
  FAILED
}

enum VoterSnapshotChangeType {
  NEW
  UPDATED
  REMOVED
  REACTIVATED
}

/// One row per SOS file import / snapshot used for diffs and county rollups.
model VoterFileSnapshot {
  id                 String                @id @default(cuid())
  createdAt          DateTime              @default(now())
  /// When the raw file was first received by our systems (optional)
  fileReceivedAt     DateTime?
  /// When the file was ingested into our system
  importedAt         DateTime              @default(now())
  /// "As of" date represented by the export (often file generation / voter roll pull date)
  fileAsOfDate       DateTime
  /// Prior snapshot this import was diffed against (if any)
  previousSnapshotId String?
  previousSnapshot   VoterFileSnapshot?    @relation("VoterFileSnapshotChain", fields: [previousSnapshotId], references: [id], onDelete: SetNull)
  nextSnapshots      VoterFileSnapshot[]   @relation("VoterFileSnapshotChain")
  sourceFilename     String?
  /// SHA-256 of raw file bytes for idempotency
  sourceFileHash     String?               @unique
  rowCountProcessed  Int?
  status             VoterFileIngestStatus @default(RECEIVED)
  errorMessage       String?               @db.Text
  /// Optional notes for operators (e.g. special election cut)
  operatorNotes      String?               @db.Text

  countyMetrics   CountyVoterMetrics[]
  firstSeenVoters VoterRecord[]         @relation("VoterFirstSeen")
  lastSeenVoters  VoterRecord[]         @relation("VoterLastSeen")
  droppedVoters   VoterRecord[]         @relation("VoterDropped")
  updatedVoters   VoterRecord[]         @relation("VoterUpdatedFrom")
  snapshotChanges VoterSnapshotChange[]

  @@index([fileAsOfDate])
  @@index([status, fileAsOfDate])
}

/// Precomputed per-county rollups for a given voter file snapshot (field program + public county pages).
model CountyVoterMetrics {
  id                                    String                    @id @default(cuid())
  countyId                              String
  county                                County                    @relation(fields: [countyId], references: [id], onDelete: Cascade)
  /// Denormalized from `County.slug` for warehouse exports and public APIs
  countySlug                            String
  voterFileSnapshotId                   String
  /// Source snapshot for this rollup (alias semantically: “source snapshot”)
  snapshot                              VoterFileSnapshot         @relation(fields: [voterFileSnapshotId], references: [id], onDelete: Cascade)
  /// Denormalized: same as snapshot.fileAsOfDate for fast reads
  asOfDate                              DateTime
  /// Must match `getCampaignRegistrationBaselineUtc()` from server config when row is written
  registrationBaselineDate              DateTime
  /// Total active registrants in file for this county at asOfDate (nullable until ETL fills)
  totalRegisteredCount                  Int?
  newRegistrationsSinceBaseline         Int                       @default(0)
  newRegistrationsSincePreviousSnapshot Int                       @default(0)
  droppedSincePreviousSnapshot          Int                       @default(0)
  netChangeSincePreviousSnapshot        Int                       @default(0)
  countyGoal                            Int?
  /// 0–100; null if goal unknown
  progressPercent                       Float?
  computedAt                            DateTime                  @default(now())
  reviewStatus                          CountyContentReviewStatus @default(PENDING_REVIEW)

  @@unique([countyId, voterFileSnapshotId])
  @@index([countySlug, asOfDate])
  @@index([asOfDate])
  @@index([countyId, asOfDate])
}

/// Canonical voter key from SOS file — used for per-import diffs and assistance tooling (not official SOS UI).
model VoterRecord {
  id                    String             @id @default(cuid())
  /// **Canonical identifier:** opaque stable key from the SOS / vendor voter file (VRN / state id—map to your column).
  voterFileKey          String             @unique
  countyFips            String
  countyId              String
  county                County             @relation(fields: [countyId], references: [id], onDelete: Cascade)
  /// Denormalized public county slug (matches `County.slug`)
  countySlug            String
  city                  String?
  precinct              String?
  registrationDate      DateTime?
  firstSeenSnapshotId   String
  firstSeen             VoterFileSnapshot  @relation("VoterFirstSeen", fields: [firstSeenSnapshotId], references: [id], onDelete: Restrict)
  lastSeenSnapshotId    String
  lastSeen              VoterFileSnapshot  @relation("VoterLastSeen", fields: [lastSeenSnapshotId], references: [id], onDelete: Restrict)
  updatedFromSnapshotId String?
  updatedFrom           VoterFileSnapshot? @relation("VoterUpdatedFrom", fields: [updatedFromSnapshotId], references: [id], onDelete: SetNull)
  /// When the voter no longer appears in the most recent file we have processed
  droppedAtSnapshotId   String?
  droppedAt             VoterFileSnapshot? @relation("VoterDropped", fields: [droppedAtSnapshotId], references: [id], onDelete: SetNull)
  /// Civil date / moment we treat as “dropped off” the roll (denormalized for reporting)
  droppedOffAt          DateTime?
  /// Denormalized from latest import: present in last completed snapshot’s file
  inLatestCompletedFile Boolean            @default(true)
  /// Filled when voter file import includes name columns; enables signup-sheet and assist matching.
  firstName             String?            @db.Text
  lastName              String?            @db.Text
  /// 10-digit US phone digits only, when import provides a phone column.
  phone10               String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  snapshotChanges          VoterSnapshotChange[]
  userLinks                User[]                    @relation("UserVoterLink")
  volunteerMatchCandidates VolunteerMatchCandidate[]
  signupEntriesMatched     SignupSheetEntry[]        @relation("SignupEntryMatchedVoter")

  @@index([countyId, inLatestCompletedFile])
  @@index([countyId, lastName, firstName])
  @@index([phone10])
  @@index([countySlug])
  @@index([countyFips])
  @@index([registrationDate])
}

/// Per-voter delta rows for a snapshot (audit + recompute). Heavy table at full state scale—archive old snapshots as needed.
model VoterSnapshotChange {
  id                  String                  @id @default(cuid())
  voterFileSnapshotId String
  snapshot            VoterFileSnapshot       @relation(fields: [voterFileSnapshotId], references: [id], onDelete: Cascade)
  voterRecordId       String?
  voterRecord         VoterRecord?            @relation(fields: [voterRecordId], references: [id], onDelete: SetNull)
  /// Always store the SOS key for traceability even if `voterRecordId` is null in edge cases
  voterFileKey        String
  changeType          VoterSnapshotChangeType
  countyId            String
  county              County                  @relation(fields: [countyId], references: [id], onDelete: Cascade)
  countySlug          String
  summaryJson         Json?
  createdAt           DateTime                @default(now())

  @@index([voterFileSnapshotId, changeType])
  @@index([countySlug, voterFileSnapshotId])
  @@index([voterFileKey])
}

// --- Campaign operations: workbench, events, tasks, workflows, asks (Slice 1) ---

enum CampaignEventType {
  RALLY
  APPEARANCE
  TRAINING
  MEETING
  CANVASS
  PHONE_BANK
  FUNDRAISER
  PRESS
  DEADLINE
  ORIENTATION
  /// Third-party fair, festival, or community gathering (often after promotion from ingest).
  FESTIVAL
  OTHER
}

enum CampaignEventStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CampaignEventVisibility {
  INTERNAL
  STAFF
  PUBLIC_STAFF
}

/// Staging / approvals — distinct from `CampaignEventStatus` (operational: scheduled, cancelled, etc.)
enum EventWorkflowState {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  CANCELED
  COMPLETED
}

/// FranklinCovey / Eisenhower time matrix: Q1 urgent+important, Q2 not urgent+important, Q3 urgent+not important, Q4 neither
enum TimeMatrixQuadrant {
  Q1
  Q2
  Q3
  Q4
}

/// Lane readiness for Calendar HQ (Slice 1 spine)
enum EventReadinessStatus {
  UNKNOWN
  NOT_STARTED
  IN_PROGRESS
  READY
  AT_RISK
  N_A
}

enum GoogleEventSyncState {
  IDLE
  PENDING_PUSH
  PENDING_PULL
  SYNCED
  CONFLICT
  ERROR
}

enum CalendarProvider {
  GOOGLE
}

enum CalendarSourceVisibility {
  STAFF
  MANAGER
  PUBLIC_CONNECTOR
}

/// Slice 5 — which campaign rail this Google calendar backs (not OAuth scope).
enum CalendarSourceType {
  CAMPAIGN_MASTER
  CANDIDATE_PUBLIC_APPEARANCES
  TRAVEL_LOGISTICS
  INTERNAL_STAFF_PLANNING
  CONTENT_MEDIA
  PERSONAL_OVERLAY
}

enum EventApprovalState {
  PENDING
  APPROVED
  REJECTED
}

/// Ingested fairs / festivals — review before public site + optional promotion to `CampaignEvent`.
enum FestivalIngestReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

enum FestivalSourceChannel {
  RSS
  WEB
  FACEBOOK
  INSTAGRAM
  GOOGLE
  MANUAL
  OTHER
  /// Submitted from the public Movement /events form — pending staff review.
  PUBLIC_FORM
}

enum EventSyncDirection {
  PUSH_TO_GOOGLE
  PULL_FROM_GOOGLE
  WATCH_PING
}

enum EventSyncLogStatus {
  OK
  ERROR
  SKIPPED
}

enum CampaignTaskType {
  PREP
  COMMS
  FIELD
  DATA
  VOLUNTEER
  MEDIA
  ADMIN
  FOLLOW_UP
  OTHER
}

enum CampaignTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum CampaignTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkflowTemplateTrigger {
  EVENT_CREATED
  EVENT_SIGNUP_CREATED
  MENTION_REVIEWED
  MANUAL
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum VolunteerAskType {
  SHARE
  RSVP
  CANVASS
  PHONE_BANK
  HOST
  RECRUIT
  AMPLIFY
  OTHER
}

enum VolunteerAskStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum EventSignupAttendeeStatus {
  REGISTERED
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum MediaIngestBatchStatus {
  STARTED
  COMPLETE
  PARTIAL
  FAILED
}

model CampaignEvent {
  id                       String                  @id @default(cuid())
  slug                     String                  @unique
  title                    String
  description              String?                 @db.Text
  eventType                CampaignEventType
  status                   CampaignEventStatus     @default(SCHEDULED)
  visibility               CampaignEventVisibility @default(INTERNAL)
  countyId                 String?
  county                   County?                 @relation(fields: [countyId], references: [id], onDelete: SetNull)
  locationName             String?
  address                  String?                 @db.Text
  startAt                  DateTime
  endAt                    DateTime
  timezone                 String                  @default("America/Chicago")
  ownerUserId              String?
  ownerUser                User?                   @relation("EventOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  relatedInboundContentId  String?
  relatedSyncedPostId      String?
  relatedOwnedMediaAssetId String?
  notes                    String?                 @db.Text
  /// Workflow for approvals + public website. Sync with `status` (e.g. CANCELED) as staff update fields. Operational source of truth for staging (alias: event "stage").
  eventWorkflowState       EventWorkflowState      @default(DRAFT)
  /// Derived visibility for the public site: only `PUBLISHED` workflow should set this true for go-live.
  isPublicOnWebsite        Boolean                 @default(false)
  /// When the event was submitted for review (DRAFT → PENDING_APPROVAL).
  submittedForReviewAt     DateTime?
  /// When the event was approved (PENDING_APPROVAL → APPROVED).
  approvedAt                 DateTime?
  approvedByUserId         String?
  approvedByUser           User?                   @relation("EventApprovedByStaff", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  /// When the event was marked completed in workflow (APPROVED/PUBLISHED → COMPLETED).
  completedAt                DateTime?
  /// When set with APPROVED/PUBLISHED + visibility, drives public /campaign-calendar.
  publicSummary            String?                 @db.Text
  calendarSourceId         String?
  calendarSource           CalendarSource?         @relation(fields: [calendarSourceId], references: [id], onDelete: SetNull)
  googleEventId            String?
  googleEtag               String?                 @db.Text
  googleSyncState          GoogleEventSyncState    @default(IDLE)
  lastGoogleSyncAt         DateTime?
  /// Last error message from Google push/pull (cleared on success).
  googleSyncError          String?                 @db.Text
  /// Inbound change may require staff attention (e.g. lifecycle mismatch).
  syncReviewNeeded         Boolean                 @default(false)
  /// When Google (or other external) last changed start/end; drives comms + task re-evaluation.
  inboundTimeChangedAt     DateTime?
  commsStateJson           Json?                   @default("{}")
  staffingStateJson        Json?                   @default("{}")
  /// AI / analytics cache (last run)
  lastAiScanAt             DateTime?
  timeMatrixQuadrant       TimeMatrixQuadrant      @default(Q2)
  /// Why this event exists / strategic intent (Calendar HQ)
  campaignIntent           String?                 @db.Text
  /// prep, comms, staffing, followUp — array of { id, label, done }
  executionChecklistJson   Json?                   @default("{}")
  contentOpportunityNotes  String?                 @db.Text
  isBigRock                Boolean                 @default(false)
  bigRockOrder             Int?
  /// Staff-only narrative (not public)
  internalSummary          String?                 @db.Text
  cancellationReason       String?                 @db.Text
  commsReadiness           EventReadinessStatus    @default(UNKNOWN)
  staffingReadiness        EventReadinessStatus    @default(UNKNOWN)
  prepReadiness            EventReadinessStatus    @default(UNKNOWN)
  followupReadiness        EventReadinessStatus    @default(UNKNOWN)
  /// Reminder / touchpoint plan for this event (Slice 3 calendar comms).
  reminderPlanStatus        EventReadinessStatus    @default(UNKNOWN)
  /// RSVP / invite / pre-event attendee messaging track.
  attendeeCommsStatus       EventReadinessStatus    @default(UNKNOWN)
  /// Post-event thank-you and volunteer follow-up track.
  followupCommsStatus       EventReadinessStatus    @default(UNKNOWN)
  lastReminderSentAt         DateTime?
  nextReminderDueAt          DateTime?
  lastAttendeeNoticeAt       DateTime?
  lastCancellationNoticeAt  DateTime?
  thankYouQueuedAt          DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  signups                EventSignup[]
  tasks                  CampaignTask[]
  asks                   VolunteerAsk[]
  /// Media assets logically tied to this campaign event (rally, etc.).
  linkedOwnedMediaAssets OwnedMediaAsset[]          @relation("OwnedMediaCampaignEvent")
  commsQueueItems        CommunicationActionQueue[]
  eventApprovals         EventApproval[]
  stageChangeLogs        EventStageChangeLog[]
  syncLogs               EventSyncLog[]             @relation("EventSyncForEvent")
  analyticsSnapshots     EventAnalyticsSnapshot[]
  weeklyBigRock          WeeklyBigRock?             @relation("BigRockEvent")
  communicationCampaigns CommunicationCampaign[]
  /// When this event was created by promoting an ingested fair/festival.
  festivalPromotionSource ArkansasFestivalIngest? @relation("FestivalPromotion")

  @@index([startAt, status])
  @@index([countyId, startAt])
  @@index([status, startAt])
  @@index([eventWorkflowState, startAt])
  @@index([isPublicOnWebsite, eventWorkflowState, startAt])
  @@index([googleEventId])
  @@index([googleSyncState, updatedAt])
}

/// Batch record for festival ingest runs (cron / manual).
model FestivalIngestRun {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  label       String?
  summaryJson Json?
  inserted    Int       @default(0)
  updated     Int       @default(0)
  skipped     Int       @default(0)
  error       String?   @db.Text
  festivals   ArkansasFestivalIngest[]
}

/// Fair, festival, or large community gathering discovered via ingest — not a campaign event until reviewed / promoted.
model ArkansasFestivalIngest {
  id                 String   @id @default(cuid())
  name               String
  shortDescription   String?  @db.Text
  startAt            DateTime
  endAt              DateTime
  timezone           String   @default("America/Chicago")
  city               String?
  countyId           String?
  county             County?  @relation(fields: [countyId], references: [id], onDelete: SetNull)
  latitude           Float?
  longitude          Float?
  venueName          String?
  sourceChannel      FestivalSourceChannel
  /// Deduplication key: canonical public URL for the listing when available.
  sourceUrl          String   @unique
  sourceFingerprint  String?
  rawPayload         Json?
  /// When source is `PUBLIC_FORM`, optional more-info link the submitter provided.
  submitterInfoUrl   String?
  /// Name/email from the public suggestion form (never shown on site; admin only).
  submitterName      String?
  submitterEmail     String?
  reviewStatus       FestivalIngestReviewStatus @default(PENDING_REVIEW)
  /// When true and `reviewStatus` is APPROVED, show on public campaign trail feed.
  isVisibleOnSite    Boolean  @default(false)
  estimatedAttendance Int?
  promotedCampaignEventId String?  @unique
  promotedCampaignEvent   CampaignEvent? @relation("FestivalPromotion", fields: [promotedCampaignEventId], references: [id], onDelete: SetNull)
  ingestRunId        String?
  ingestRun          FestivalIngestRun? @relation(fields: [ingestRunId], references: [id], onDelete: SetNull)
  lastSeenInIngestAt DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([startAt, reviewStatus])
  @@index([countyId, startAt])
  @@index([isVisibleOnSite, startAt, reviewStatus])
}

/// Cached AI output: weekend coverage + volunteer routing suggestions.
model FestivalCoveragePlanSnapshot {
  id          String   @id @default(cuid())
  generatedAt DateTime @default(now())
  validFrom   DateTime
  validTo     DateTime
  modelName   String?
  payload     Json
}

model CampaignTask {
  id                 String               @id @default(cuid())
  title              String
  description        String?              @db.Text
  taskType           CampaignTaskType     @default(OTHER)
  status             CampaignTaskStatus   @default(TODO)
  priority           CampaignTaskPriority @default(MEDIUM)
  dueAt              DateTime?
  startAt            DateTime?
  assignedUserId     String?
  assignee           User?                @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedRole       String?
  /// When true, incomplete state drags event execution / readiness (Slice 4).
  blocksReadiness    Boolean              @default(false)
  /// Idempotency: `WorkflowTemplateTask.taskKey` that created this row.
  sourceTemplateTaskKey String?
  countyId           String?
  county             County?              @relation(fields: [countyId], references: [id], onDelete: SetNull)
  eventId            String?
  event              CampaignEvent?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  workflowRunId      String?
  workflowRun        WorkflowRun?         @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  parentTaskId       String?
  parentTask         CampaignTask?        @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks           CampaignTask[]       @relation("Subtasks")
  createdByUserId    String?
  creator            User?                @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completionNotes    String?              @db.Text
  completedAt        DateTime?
  timeMatrixQuadrant TimeMatrixQuadrant?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status, dueAt])
  @@index([assignedUserId, status])
  @@index([eventId])
  @@index([eventId, sourceTemplateTaskKey])
  @@index([dueAt, status])
}

model WorkflowTemplate {
  id          String                  @id @default(cuid())
  key         String                  @unique
  title       String
  description String?                 @db.Text
  triggerType WorkflowTemplateTrigger
  /// When set, this template is the default pack for calendar events of this type (Slice 4).
  campaignEventType CampaignEventType?
  isActive    Boolean                 @default(true)
  configJson  Json                    @default("{}")
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  tasks WorkflowTemplateTask[]
  runs  WorkflowRun[]

  @@index([campaignEventType])
}

model WorkflowTemplateTask {
  id                  String               @id @default(cuid())
  workflowTemplateId  String
  workflowTemplate    WorkflowTemplate     @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  taskKey             String
  titleTemplate       String
  descriptionTemplate String?              @db.Text
  offsetMinutes       Int                  @default(0)
  roleTarget          String?
  taskType            CampaignTaskType     @default(OTHER)
  priority            CampaignTaskPriority @default(MEDIUM)
  required            Boolean              @default(true)
  /// When true, this line blocks event readiness until done.
  blocksReadiness     Boolean              @default(false)
  /// Generate this task only once the event workflow stage is at or past this point (null = any).
  minEventStage       EventWorkflowState?
  dependsOnTaskKey    String?
  configJson          Json?                @default("{}")

  @@unique([workflowTemplateId, taskKey])
  @@index([workflowTemplateId])
}

model WorkflowRun {
  id                 String                  @id @default(cuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate        @relation(fields: [workflowTemplateId], references: [id], onDelete: Restrict)
  triggerType        WorkflowTemplateTrigger
  triggerSourceType  String
  triggerSourceId    String
  status             WorkflowRunStatus       @default(RUNNING)
  startedAt          DateTime                @default(now())
  completedAt        DateTime?
  contextJson        Json?                   @default("{}")
  errorMessage       String?                 @db.Text
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  tasks         CampaignTask[]
  volunteerAsks VolunteerAsk[]

  @@unique([workflowTemplateId, triggerSourceType, triggerSourceId])
  @@index([status, createdAt])
}

model VolunteerAsk {
  id                 String             @id @default(cuid())
  title              String
  description        String?            @db.Text
  askType            VolunteerAskType
  status             VolunteerAskStatus @default(DRAFT)
  priority           Int                @default(0)
  countyId           String?
  county             County?            @relation(fields: [countyId], references: [id], onDelete: SetNull)
  eventId            String?
  event              CampaignEvent?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  workflowRunId      String?
  workflowRun        WorkflowRun?       @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  startsAt           DateTime?
  endsAt             DateTime?
  recurrenceRule     String?
  targetAudienceJson Json?              @default("{}")
  actionUrl          String?
  completionMode     String             @default("HONOR_SYSTEM")
  createdByUserId    String?
  createdBy          User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status, startsAt])
  @@index([countyId, status])
}

model EventSignup {
  id                 String                    @id @default(cuid())
  eventId            String
  event              CampaignEvent             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId             String?
  user               User?                     @relation("UserEventSignups", fields: [userId], references: [id], onDelete: SetNull)
  volunteerProfileId String?
  volunteerProfile   VolunteerProfile?         @relation(fields: [volunteerProfileId], references: [id], onDelete: SetNull)
  firstName          String
  lastName           String
  email              String
  mobilePhone        String?
  countyId           String?
  county             County?                   @relation(fields: [countyId], references: [id], onDelete: SetNull)
  signupSource       String                    @default("web")
  notes              String?                   @db.Text
  status             EventSignupAttendeeStatus @default(REGISTERED)
  attendedAt         DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([eventId, createdAt])
  @@index([email])
}

model TeamRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleKey   String
  countyId  String?
  county    County?  @relation(fields: [countyId], references: [id], onDelete: SetNull)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, roleKey])
  @@index([countyId, roleKey])
}

model MediaIngestBatch {
  id              String                 @id @default(cuid())
  sourceType      String
  sourceLabel     String
  ingestPath      String?                @db.Text
  status          MediaIngestBatchStatus @default(STARTED)
  importedCount   Int                    @default(0)
  duplicateCount  Int                    @default(0)
  failedCount     Int                    @default(0)
  startedAt       DateTime               @default(now())
  finishedAt      DateTime?
  notes           String?                @db.Text
  createdByUserId String?
  createdBy       User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  assets OwnedMediaAsset[]

  @@index([status, createdAt])
}

// --- Volunteer signup sheet intake (image/PDF → rows → voter match → admin approval) ---

enum SignupSheetDocumentStatus {
  DRAFT
  QUEUED
  EXTRACTING
  EXTRACTED
  PARTIAL
  FAILED
}

enum SignupSheetExtractionStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum SignupSheetEntryStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SKIPPED
}

model SignupSheetDocument {
  id               String                    @id @default(cuid())
  ownedMediaId     String                    @unique
  ownedMedia       OwnedMediaAsset           @relation(fields: [ownedMediaId], references: [id], onDelete: Cascade)
  status           SignupSheetDocumentStatus @default(DRAFT)
  lastExtractionId String?
  lastExtraction   SignupSheetExtraction?    @relation("DocumentLastExtraction", fields: [lastExtractionId], references: [id], onDelete: SetNull)
  notes            String?                   @db.Text
  createdByUserId  String?
  createdBy        User?                     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  extractions SignupSheetExtraction[] @relation("DocumentExtractions")
  entries     SignupSheetEntry[]

  @@index([status, updatedAt])
}

model SignupSheetExtraction {
  id               String                      @id @default(cuid())
  documentId       String
  document         SignupSheetDocument         @relation("DocumentExtractions", fields: [documentId], references: [id], onDelete: Cascade)
  status           SignupSheetExtractionStatus @default(PENDING)
  model            String?
  rawOcrText       String?                     @db.Text
  parsedOutputJson Json?
  errorMessage     String?                     @db.Text
  avgConfidence    Float?
  createdAt        DateTime                    @default(now())

  entries        SignupSheetEntry[]
  documentAsLast SignupSheetDocument[] @relation("DocumentLastExtraction")

  @@index([documentId, createdAt])
}

model SignupSheetEntry {
  id           String                @id @default(cuid())
  documentId   String
  document     SignupSheetDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractionId String
  extraction   SignupSheetExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  rowIndex     Int

  firstName  String? @db.Text
  lastName   String? @db.Text
  phone      String? @db.Text
  email      String? @db.Text
  address    String? @db.Text
  countyText String? @db.Text
  countyId   String?
  county     County? @relation(fields: [countyId], references: [id], onDelete: SetNull)

  rawRowText      String @db.Text
  parsedJson      Json?
  confidenceScore Float?

  approvalStatus       SignupSheetEntryStatus @default(PENDING_REVIEW)
  matchedVoterRecordId String?
  matchedVoterRecord   VoterRecord?           @relation("SignupEntryMatchedVoter", fields: [matchedVoterRecordId], references: [id], onDelete: SetNull)
  matchedUserId        String?
  matchedUser          User?                  @relation(fields: [matchedUserId], references: [id], onDelete: SetNull)
  notes                String?                @db.Text
  decidedAt            DateTime?
  decisionNote         String?                @db.Text

  matchCandidates VolunteerMatchCandidate[]

  @@index([documentId, approvalStatus])
  @@index([extractionId, rowIndex])
  @@index([approvalStatus, confidenceScore])
}

model VolunteerMatchCandidate {
  id            String           @id @default(cuid())
  entryId       String
  entry         SignupSheetEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  voterRecordId String
  voterRecord   VoterRecord      @relation(fields: [voterRecordId], references: [id], onDelete: Cascade)
  score         Float
  reasonJson    Json             @default("{}")
  rank          Int              @default(0)

  createdAt DateTime @default(now())

  @@unique([entryId, voterRecordId])
  @@index([entryId, score])
}

// --- CampaignOS Step 1: Communications engine ---

enum CommunicationChannel {
  SMS
  EMAIL
}

enum CommunicationThreadStatus {
  ACTIVE
  NEEDS_REPLY
  FOLLOW_UP
  CLOSED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum CommsSendProvider {
  TWILIO
  SENDGRID
  GMAIL
  MANUAL
  SYSTEM
}

enum MessageDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  OPENED
  CLICKED
  RECEIVED
}

enum CommunicationActionType {
  SEND_SMS
  SEND_EMAIL
  SEND_REMINDER
  AI_SUGGEST_FOLLOWUP
  CAL_REMINDER_DUE
  CAL_EVENT_CHANGED
  CAL_CANCELLATION_NOTICE
  CAL_RSVP_FOLLOWUP
  CAL_THANK_YOU_FOLLOWUP
  CAL_COUNTY_LEAD_MISSING
  CAL_MEDIA_CAPTURE_MISSING
  CAL_COMMS_PREP_MISSING
  CAL_STAFFING_GAP
}

enum CommsQueueStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
  CANCELED
}

model CommunicationThread {
  id                 String                    @id @default(cuid())
  userId             String?
  user               User?                     @relation("ThreadPrimaryUser", fields: [userId], references: [id], onDelete: SetNull)
  volunteerProfileId String?
  volunteerProfile   VolunteerProfile?         @relation(fields: [volunteerProfileId], references: [id], onDelete: SetNull)
  primaryEmail       String?
  primaryPhone       String?
  preferredChannel   CommunicationChannel?
  threadStatus       CommunicationThreadStatus @default(ACTIVE)
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  lastMessageAt      DateTime?
  unreadCount        Int                       @default(0)
  priorityScore      Int                       @default(0)
  countyId           String?
  county             County?                   @relation(fields: [countyId], references: [id], onDelete: SetNull)
  assignedUserId     String?
  assignee           User?                     @relation("ThreadAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedRoleKey    String?
  notes              String?                   @db.Text
  /// AI-generated short summary of recent messages (refreshed on demand).
  aiThreadSummary    String?                   @db.Text
  /// AI-suggested one-line next step for staff.
  aiNextBestAction   String?                   @db.Text
  /// DB column retained from earlier migration naming (`lastStaffTouchAt`).
  lastTouchedAt      DateTime?                 @map("lastStaffTouchAt")
  nextActionDueAt    DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  messages                CommunicationMessage[]
  actionQueue             CommunicationActionQueue[]
  tagAssignments          CommunicationThreadTag[]
  contactPreferenceRecord ContactPreference?
  campaignRecipients  CommunicationCampaignRecipient[]

  @@index([threadStatus, lastMessageAt])
  @@index([unreadCount, priorityScore])
  @@index([countyId, threadStatus])
  @@index([userId])
  @@index([lastMessageAt])
}

model CommunicationMessage {
  id                String                @id @default(cuid())
  threadId          String
  thread            CommunicationThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  /// Broadcast/campaign (Tier 2): optional when send is from a `CommunicationCampaign`.
  communicationCampaignId String?
  communicationCampaign  CommunicationCampaign? @relation(fields: [communicationCampaignId], references: [id], onDelete: SetNull)
  /// Link back to the campaign recipient row (1:1 when sent through broadcast).
  communicationCampaignRecipientId String?  @unique
  campaignRecipient    CommunicationCampaignRecipient? @relation("MsgCampaignRecipient", fields: [communicationCampaignRecipientId], references: [id], onDelete: SetNull)
  channel           CommunicationChannel
  direction         MessageDirection
  provider          CommsSendProvider
  providerMessageId String?
  fromAddress       String?
  toAddress         String?
  subject           String?
  bodyText          String                @db.Text
  bodyHtml          String?               @db.Text
  deliveryStatus    MessageDeliveryStatus @default(QUEUED)
  openedAt          DateTime?
  clickedAt         DateTime?
  failedAt          DateTime?
  errorMessage      String?               @db.Text
  aiGenerated       Boolean               @default(false)
  aiPromptSummary   String?               @db.Text
  sentByUserId      String?
  sentBy            User?                 @relation("MessageSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  /// Gmail API identifiers when `provider` is GMAIL (thread continuity for staff replies).
  gmailMessageId    String?               @db.Text
  gmailThreadId     String?               @db.Text
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([threadId, createdAt])
  @@index([provider, providerMessageId])
  @@index([communicationCampaignId, createdAt])
  @@index([gmailMessageId])
}

enum CommunicationCampaignChannel {
  SMS
  EMAIL
  MIXED
}

enum CommunicationCampaignType {
  BROADCAST
  EVENT_REMINDER
  FOLLOW_UP
  FUNDRAISING
  VOLUNTEER_RECRUITMENT
  INTERNAL
  EVENT_CANCELLATION
  EVENT_THANK_YOU
  RSVP_FOLLOWUP
}

enum CommunicationCampaignStatus {
  DRAFT
  APPROVAL_NEEDED
  APPROVED
  QUEUED
  SENDING
  PAUSED
  COMPLETE
  FAILED
  CANCELED
}

/// Tier 3B: event-driven / orchestration — `SHELL` = auto-generated, awaiting human review.
enum CommunicationCampaignAutomationStatus {
  NONE
  SHELL
}

enum CommunicationTemplateType {
  BROADCAST
  EVENT_REMINDER
  QUICK_REPLY
  SYSTEM
}

enum CampaignRecipientSendStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  SKIPPED_SUPPRESSION
  SKIPPED_NO_ADDRESS
  CANCELED
  BOUNCED
}

model CommunicationTemplate {
  id             String                 @id @default(cuid())
  name           String
  channel        CommunicationChannel
  templateType   CommunicationTemplateType @default(BROADCAST)
  subjectTemplate String?               @db.Text
  bodyTemplate   String                 @db.Text
  tone           String?
  isAiSeeded     Boolean                @default(false)
  isSystem       Boolean                @default(false)
  eventType      CampaignEventType?
  createdByUserId String?
  createdBy        User?                 @relation("TemplateAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  campaigns        CommunicationCampaign[]

  @@index([templateType, channel])
}

model AudienceSegment {
  id               String  @id @default(cuid())
  name             String
  definitionJson   Json   @default("{}")
  estimatedCount   Int?
  isDynamic        Boolean @default(true)
  createdByUserId  String?
  createdBy         User?   @relation("SegmentAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  campaigns         CommunicationCampaign[]

  @@index([name])
}

model CommunicationCampaign {
  id                   String                      @id @default(cuid())
  name                 String
  channel              CommunicationCampaignChannel
  campaignType         CommunicationCampaignType   @default(BROADCAST)
  status               CommunicationCampaignStatus   @default(DRAFT)
  templateId           String?
  template             CommunicationTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  audienceDefinitionJson Json                      @default("{}")
  audienceSegmentId    String?
  audienceSegment      AudienceSegment?            @relation(fields: [audienceSegmentId], references: [id], onDelete: SetNull)
  /// Copy from template at send time or ad-hoc content when no template.
  subjectText          String?                     @db.Text
  bodyText             String?                     @db.Text
  eventId              String?
  event                CampaignEvent?              @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdByUserId      String?
  createdBy            User?                       @relation("CampaignAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUserId     String?
  approvedBy            User?                      @relation("CampaignApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  scheduledAt          DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  /// Denormalized for dashboard (also derived from `recipients` when needed).
  totalRecipients      Int                         @default(0)
  suppressedCount      Int                         @default(0)
  sentCount            Int                         @default(0)
  deliveredCount       Int                         @default(0)
  failedCount          Int                         @default(0)
  replyCount           Int                         @default(0)
  optOutCount          Int                         @default(0)
  /// First open / click (email engagement via SendGrid webhooks) — denormalized counts.
  engagementOpenCount  Int                         @default(0)
  engagementClickCount Int                         @default(0)
  statsJson            Json?                       @default("{}")
  notes                String?                     @db.Text
  lastProcessError     String?                     @db.Text
  processingLockUntil  DateTime?
  /// Idempotency for cron worker picking up the same job.
  lastProcessedAt      DateTime?
  /// Tier 3B: stable `event:{eventId}:{kind}` to prevent duplicate auto shells.
  orchestrationIdempotencyKey String?    @unique
  triggerSourceType          String?
  triggerSourceId            String?
  generatedFromTemplateKey  String?     @db.Text
  automationStatus           CommunicationCampaignAutomationStatus @default(NONE)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  recipients           CommunicationCampaignRecipient[]
  messages             CommunicationMessage[]

  @@index([status, scheduledAt])
  @@index([eventId, status])
  @@index([status, createdAt])
  @@index([automationStatus, status])
  @@index([triggerSourceType, triggerSourceId])
}

model CommunicationCampaignRecipient {
  id                      String   @id @default(cuid())
  communicationCampaignId String
  campaign                 CommunicationCampaign @relation(fields: [communicationCampaignId], references: [id], onDelete: Cascade)
  userId                  String?
  user                    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  volunteerProfileId     String?
  volunteerProfile        VolunteerProfile? @relation(fields: [volunteerProfileId], references: [id], onDelete: SetNull)
  communicationThreadId   String?
  thread                  CommunicationThread? @relation(fields: [communicationThreadId], references: [id], onDelete: SetNull)
  channel                 CommunicationChannel
  recipientEmail          String?
  recipientPhone         String?
  personalizationJson   Json   @default("{}")
  sendStatus              CampaignRecipientSendStatus @default(PENDING)
  providerMessageId      String?
  deliveredAt            DateTime?
  failedAt               DateTime?
  responseAt             DateTime?
  unsubscribeStateSnapshot Json? @default("{}")
  lastError              String? @db.Text
  attemptCount            Int   @default(0)
  idempotencyKey         String? @unique
  /// Email engagement (from SendGrid open/click webhooks) — one timestamp each (first / last).
  engagementOpenedAt     DateTime?
  engagementClickedAt     DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  linkedOutMessage        CommunicationMessage? @relation("MsgCampaignRecipient")

  @@index([communicationCampaignId, sendStatus])
  @@index([communicationCampaignId, id])
  @@index([userId])
  @@index([sendStatus, updatedAt])
}

model CommunicationActionQueue {
  id                       String                  @id @default(cuid())
  actionType               CommunicationActionType
  eventId                  String?
  event                    CampaignEvent?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  threadId                 String?
  thread                   CommunicationThread?    @relation(fields: [threadId], references: [id], onDelete: SetNull)
  targetUserId             String?
  targetUser               User?                   @relation("QueueTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetVolunteerProfileId String?
  targetVolunteer          VolunteerProfile?       @relation("QueueTargetVolunteer", fields: [targetVolunteerProfileId], references: [id], onDelete: SetNull)
  payloadJson              Json                    @default("{}")
  queueStatus              CommsQueueStatus        @default(PENDING)
  scheduledAt              DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  failedAt                 DateTime?
  attemptCount             Int                     @default(0)
  lastError                String?                 @db.Text
  createdByUserId          String?
  createdBy                User?                   @relation("QueueCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([queueStatus, scheduledAt])
  @@index([threadId])
  @@index([queueStatus, createdAt])
  @@index([eventId, queueStatus])
}

model CommunicationTag {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  threads CommunicationThreadTag[]
}

model CommunicationThreadTag {
  threadId  String
  thread    CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tagId     String
  tag       CommunicationTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())

  @@id([threadId, tagId])
  @@index([tagId])
}

/// OAuth-linked Google mailbox for 1:1 human email from the workbench (Gmail API). Not used for SendGrid broadcast.
model StaffGmailAccount {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Workspace / Gmail “send as” address (usually same as `User.email`).
  sendAsEmail String
  oauthJson   Json   @default("{}")
  isActive    Boolean @default(true)
  lastError   String? @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Calendar HQ / Google Calendar (CampaignOS) ---

model CalendarSource {
  id                 String                   @id @default(cuid())
  /// Short machine label (kept for back-compat; prefer `displayName` in UI when set).
  label              String
  /// Staff-facing name (e.g. “Candidate — public appearances”).
  displayName        String?
  /// CampaignOS rail for routing outbound events (Slice 5).
  sourceType         CalendarSourceType       @default(INTERNAL_STAFF_PLANNING)
  /// When true, eligible as the *public* Google target for PUBLISHED + on-site events.
  isPublicFacing     Boolean                  @default(false)
  provider           CalendarProvider         @default(GOOGLE)
  /// Google `calendarId` (e.g. primary, or group calendar)
  externalCalendarId String
  color              String?
  visibility         CalendarSourceVisibility @default(STAFF)
  isActive           Boolean                  @default(true)
  syncEnabled        Boolean                  @default(true)
  /// Incremental list sync
  syncToken          String?                  @db.Text
  /// OAuth tokens (use env encryption in app layer for production)
  oauthJson          Json?                    @default("{}")
  lastFullSyncAt     DateTime?
  lastIncrementalAt  DateTime?
  ownerUserId        String?
  owner              User?                    @relation("CalendarSourceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  events        CampaignEvent[]
  watchChannels CalendarWatchChannel[]
  syncLogs      EventSyncLog[]         @relation("EventSyncBySource")

  @@index([sourceType, isActive, syncEnabled])
  @@index([isPublicFacing, isActive, syncEnabled])
}

model CalendarWatchChannel {
  id               String         @id @default(cuid())
  calendarSourceId String
  calendarSource   CalendarSource @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade)
  channelId        String
  resourceId       String
  /// Google’s channel token
  token            String?
  expiration       DateTime
  lastRenewedAt    DateTime?
  lastError        String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([calendarSourceId, expiration])
  @@index([channelId])
}

/// Monday-start week; mission, outcomes, role commitments, and up to 5 big rocks
model WeeklyCampaignPlan {
  id                  String          @id @default(cuid())
  /// Inclusive start of week (00:00 local stored as DateTime, normalized in app to Monday)
  weekStart           DateTime        @unique
  missionStatement    String?         @db.Text
  outcome1            String?         @db.Text
  outcome2            String?         @db.Text
  outcome3            String?         @db.Text
  /// e.g. { "candidate", "field", "comms", ... } — free text per role key
  roleCommitmentsJson Json?           @default("{}")
  bigRocks            WeeklyBigRock[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([weekStart])
}

model WeeklyBigRock {
  id         String             @id @default(cuid())
  weekPlanId String
  weekPlan   WeeklyCampaignPlan @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  sortOrder  Int                @default(0)
  title      String
  notes      String?            @db.Text
  /// Optional link: times come from the event
  eventId    String?            @unique
  event      CampaignEvent?     @relation("BigRockEvent", fields: [eventId], references: [id], onDelete: SetNull)
  /// Synthetic block when not linked to an event
  startAt    DateTime?
  endAt      DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([weekPlanId, sortOrder])
}

model EventApproval {
  id                String             @id @default(cuid())
  eventId           String
  event             CampaignEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  round             Int                @default(1)
  state             EventApprovalState @default(PENDING)
  note              String?            @db.Text
  submittedByUserId String?
  submittedBy       User?              @relation("ApprovalSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  approverUserId    String?
  approver          User?              @relation("ApprovalDecidedBy", fields: [approverUserId], references: [id], onDelete: SetNull)
  decidedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([eventId, state])
  @@index([state, createdAt])
}

/// Append-only audit of workflow transitions (operational history).
model EventStageChangeLog {
  id            String                @id @default(cuid())
  eventId       String
  event         CampaignEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fromState     EventWorkflowState?
  toState       EventWorkflowState
  actorUserId   String?
  actor         User?                 @relation("EventStageChangeActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  /// Staff note on this transition (approval note, send-back reason, cancel reason ref, etc.).
  note          String?               @db.Text
  createdAt     DateTime              @default(now())

  @@index([eventId, createdAt])
  @@index([toState, createdAt])
}

model EventSyncLog {
  id               String             @id @default(cuid())
  eventId          String?
  event            CampaignEvent?     @relation("EventSyncForEvent", fields: [eventId], references: [id], onDelete: SetNull)
  calendarSourceId String?
  calendarSource   CalendarSource?    @relation("EventSyncBySource", fields: [calendarSourceId], references: [id], onDelete: SetNull)
  direction        EventSyncDirection
  status           EventSyncLogStatus
  message          String?            @db.Text
  detailJson       Json?              @default("{}")
  createdAt        DateTime           @default(now())

  @@index([eventId, createdAt])
  @@index([calendarSourceId, createdAt])
}

model EventAnalyticsSnapshot {
  id          String         @id @default(cuid())
  /// Calendar day in campaign TZ (date-only, UTC midnight is fine for aggregation)
  day         DateTime
  /// GLOBAL = whole campaign, EVENT = one event, COUNTY = county roll-up
  scope       String
  eventId     String?
  event       CampaignEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  countyId    String?
  county      County?        @relation(fields: [countyId], references: [id], onDelete: SetNull)
  metricsJson Json           @default("{}")
  createdAt   DateTime       @default(now())

  @@index([day, scope])
  @@index([countyId, day])
  @@index([eventId, day])
}

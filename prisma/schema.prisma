model CommunicationPlan {
  id                        String                  @id @default(cuid())
  title                     String
  objective                 CommunicationObjective
  status                    CommunicationPlanStatus @default(DRAFT)
  /// Reuses the shared campaign task priority scale (single-tenant / campaign-local deployment).
  priority                  CampaignTaskPriority    @default(MEDIUM)
  summary                   String?                 @db.Text
  ownerUserId               String?
  ownerUser                 User?                   @relation("CommsPlanOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  requestedByUserId         String?
  requestedByUser           User?                   @relation("CommsPlanRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  /// Optional provenance: why this plan exists (e.g. `INTAKE`, `TASK`); see also FKs and `metadataJson`.
  sourceType                String?
  sourceWorkflowIntakeId    String?
  sourceWorkflowIntake      WorkflowIntake?         @relation("CommsPlanSourceIntake", fields: [sourceWorkflowIntakeId], references: [id], onDelete: SetNull)
  sourceCampaignTaskId      String?
  sourceCampaignTask        CampaignTask?           @relation("CommsPlanSourceTask", fields: [sourceCampaignTaskId], references: [id], onDelete: SetNull)
  sourceEventId             String?
  sourceEvent               CampaignEvent?          @relation("CommsPlanSourceEvent", fields: [sourceEventId], references: [id], onDelete: SetNull)
  sourceSocialContentItemId String?
  sourceSocialContentItem   SocialContentItem?      @relation("CommsPlanSourceSocial", fields: [sourceSocialContentItemId], references: [id], onDelete: SetNull)
  dueAt                     DateTime?
  scheduledAt               DateTime?
  approvedAt                DateTime?
  metadataJson              Json                    @default("{}")
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  drafts                    CommunicationDraft[]
  sends                     CommunicationSend[]
  mediaOutreachItems        MediaOutreachItem[]

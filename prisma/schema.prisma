generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  zip       String?
  county    String?
  interests String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  volunteerProfile                 VolunteerProfile?
  commitments                      Commitment[]
  submissions                      Submission[]
  teamRoleAssignments              TeamRoleAssignment[]
  eventsOwned                      CampaignEvent[]                  @relation("EventOwner")
  tasksAssigned                    CampaignTask[]                   @relation("TaskAssignee")
  tasksCreated                     CampaignTask[]                   @relation("TaskCreator")
  volunteerAsksCreated             VolunteerAsk[]
  mediaIngestBatches               MediaIngestBatch[]
  ownedMediaAnnotationsOwned       OwnedMediaAnnotation[]           @relation("AnnotationAuthor")
  /// Optional: voter roll row linked for campaign assistance (admin-approved intake).
  linkedVoterRecordId              String?
  linkedVoterRecord                VoterRecord?                     @relation("UserVoterLink", fields: [linkedVoterRecordId], references: [id], onDelete: SetNull)
  volunteerSignupIntakes           SignupSheetDocument[]
  intakeMatchedEntries             SignupSheetEntry[]
  communicationThreads             CommunicationThread[]            @relation("ThreadPrimaryUser")
  threadsAssigned                  CommunicationThread[]            @relation("ThreadAssignee")
  messagesSent                     CommunicationMessage[]           @relation("MessageSentBy")
  queueItemsCreated                CommunicationActionQueue[]       @relation("QueueCreatedBy")
  queueItemsTarget                 CommunicationActionQueue[]       @relation("QueueTargetUser")
  eventApprovalsSubmitted          EventApproval[]                  @relation("ApprovalSubmittedBy")
  eventApprovalsDecided            EventApproval[]                  @relation("ApprovalDecidedBy")
  eventStageChangesActed           EventStageChangeLog[]            @relation("EventStageChangeActor")
  eventsApprovedAsStaff            CampaignEvent[]                  @relation("EventApprovedByStaff")
  calendarSourcesOwned             CalendarSource[]                 @relation("CalendarSourceOwner")
  contactPreference                ContactPreference?
  communicationTemplatesCreated    CommunicationTemplate[]          @relation("TemplateAuthor")
  audienceSegmentsCreated          AudienceSegment[]                @relation("SegmentAuthor")
  communicationCampaignsCreated    CommunicationCampaign[]          @relation("CampaignAuthor")
  communicationCampaignsApproved   CommunicationCampaign[]          @relation("CampaignApprover")
  eventSignups                     EventSignup[]                    @relation("UserEventSignups")
  communicationCampaignRecipients  CommunicationCampaignRecipient[]
  /// Staff “human” Gmail rail (at most one linked mailbox; OAuth in `StaffGmailAccount`).
  staffGmailAccount                StaffGmailAccount?
  workflowIntakesAssigned          WorkflowIntake[]                 @relation("WorkflowIntakeAssignee")
  workflowActionsPerformed         WorkflowAction[]                 @relation("WorkflowActionActor")
  socialContentItemsAuthored       SocialContentItem[]              @relation("SocialContentAuthor")
  socialContentMediaRefsCreated    SocialContentMediaRef[]          @relation("SocialMediaRefCreator")
  conversationWatchlistsCreated    ConversationWatchlist[]          @relation("WatchlistCreator")
  conversationOpportunitiesCreated ConversationOpportunity[]        @relation("OpportunityCreator")
  ownedMediaReviewLogs             OwnedMediaReviewLog[]
  ownedMediaAssetsReviewed         OwnedMediaAsset[]                @relation("OwnedMediaReviewedBy")
  socialContentDraftsCreated       SocialContentDraft[]             @relation("SocialContentDraftAuthor")
  /// Comms Workbench (ops layer)
  commsPlansOwned                  CommunicationPlan[]              @relation("CommsPlanOwner")
  commsPlansRequested              CommunicationPlan[]              @relation("CommsPlanRequester")
  commsDraftsCreated               CommunicationDraft[]             @relation("CommsDraftCreator")
  commsDraftsUpdated               CommunicationDraft[]             @relation("CommsDraftUpdater")
  commsDraftReviewRequests         CommunicationDraft[]             @relation("CommsDraftReviewRequester")
  commsDraftReviews                CommunicationDraft[]             @relation("CommsDraftReviewer")
  commsVariantReviewRequests       CommunicationVariant[]           @relation("CommsVariantReviewRequester")
  commsVariantReviews              CommunicationVariant[]           @relation("CommsVariantReviewer")
  commsSendsSent                   CommunicationSend[]              @relation("CommsSendSender")
  commsSendsQueued                 CommunicationSend[]              @relation("CommsSendQueuedBy")
  commsSendsLastRetried            CommunicationSend[]              @relation("CommsSendLastRetriedBy")
  /// Message-plan audience segments (Comms workbench; CE-1) — not broadcast `AudienceSegment`.
  commsPlanSegmentsCreated         CommsPlanAudienceSegment[]       @relation("CommsPlanSegmentCreatedBy")
  commsPlanSegmentsUpdated         CommsPlanAudienceSegment[]       @relation("CommsPlanSegmentUpdatedBy")
  commsPlanSegmentMembersAdded     CommsPlanAudienceSegmentMember[] @relation("CommsPlanSegmentMemberAddedBy")
  commsPlanSegmentMemberSubjects   CommsPlanAudienceSegmentMember[] @relation("CommsPlanSegmentMemberSubject")
  workbenchCommunicationRecipients CommunicationRecipient[]         @relation("CommunicationRecipientUser")
  /// E-1+ Email Workflow Intelligence (distinct from `CommunicationActionQueue` AI/ops queue).
  emailWorkflowItemsCreated  EmailWorkflowItem[] @relation("EmailWorkflowItemCreatedBy")
  emailWorkflowItemsAssigned EmailWorkflowItem[] @relation("EmailWorkflowItemAssignedTo")
  emailWorkflowItemsReviewed EmailWorkflowItem[] @relation("EmailWorkflowItemReviewedBy")
  /// Contact / counterpart user on a workflow item (optional).
  emailWorkflowItemsContact  EmailWorkflowItem[] @relation("EmailWorkflowItemContactUser")
  /// SEAT-1: at most one primary row per `positionKey` in `PositionSeat` (operational org seat; not permissions).
  positionSeatsOccupied          PositionSeat[]                   @relation("PositionSeatOccupant")
  /// COMP-2: compliance documents uploaded from admin (metadata + file pointer; not auto-trusted for AI).
  complianceDocumentsUploaded    ComplianceDocument[]              @relation("ComplianceDocumentUploader")
  /// FIN-1: optional “related party” for a ledger line (e.g. submitter) — not exclusive owner of the row.
  financialTransactionsRelated   FinancialTransaction[]            @relation("FinancialTransactionRelatedUser")
}

/// COMP-2: classification for dashboard-uploaded compliance knowledge files.
enum ComplianceDocumentType {
  SOS_ETHICS_FORM
  FILING_INSTRUCTIONS
  PRIOR_SUBMITTED_REPORT
  RECEIPT
  REIMBURSEMENT
  BANK_OR_EXPORT_STATEMENT
  POLICY_MEMO
  COUNSEL_GUIDANCE
  DEADLINE_CALENDAR
  DISCLAIMER_OR_TEMPLATE
  OTHER
}

/// COMP-2: admin-uploaded compliance documents (local disk storage key; RAG/index wiring is a later packet).
model ComplianceDocument {
  id       String  @id @default(cuid())
  /// Path segment from `saveOwnedMediaFile` (same data dir pattern as owned media).
  storageKey       String
  fileName         String
  originalFileName String?
  mimeType         String
  fileSizeBytes    Int
  title            String
  documentType     ComplianceDocumentType @default(OTHER)
  /// Free text (e.g. "Q1 2026", "Pre-primary") — not validated as a legal period.
  reportingPeriod  String?
  /// Optional single anchor date (reporting or document date).
  periodDate       DateTime?
  notes            String? @db.Text
  /// Staff must opt in; uploads default false (uploaded ≠ trusted for RAG).
  approvedForAiReference Boolean @default(false)
  uploadedByUserId       String?
  uploadedBy               User?   @relation("ComplianceDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentType, createdAt])
  @@index([createdAt])
  @@index([approvedForAiReference, createdAt])
}

/// FIN-1: internal ledger line — not a bank feed, not an official filing record.
enum FinancialTransactionType {
  EXPENSE
  REIMBURSEMENT
  OTHER
}

/// FIN-1: how the row was created (provenance for audit).
enum FinancialSourceType {
  MANUAL
  SUBMISSION
  DOCUMENT
  FUTURE_INTEGRATION
}

/// FIN-1: human confirmation (drafts are not treated as final spend truth).
enum FinancialTransactionStatus {
  DRAFT
  CONFIRMED
}

/// FIN-1: minimal durable financial activity row (campaign-internal; auditable, reversible by correction rows later).
model FinancialTransaction {
  id     String  @id @default(cuid())
  amount Decimal @db.Decimal(14, 2)
  transactionType  FinancialTransactionType
  /// Category slug or label (e.g. `event`, `software_platform`) — map to `CostBearingWireKind` in `budget.ts` for governance views.
  category         String
  description      String   @db.Text
  sourceType       FinancialSourceType
  /// Id in the source system: submission id, compliance document id, import batch id, etc. — not globally unique across types; pair with `sourceType`.
  sourceId         String?
  transactionDate  DateTime
  relatedUserId    String?
  relatedUser      User?    @relation("FinancialTransactionRelatedUser", fields: [relatedUserId], references: [id], onDelete: SetNull)
  relatedEventId   String?
  relatedEvent     CampaignEvent? @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)
  notes            String?  @db.Text
  status           FinancialTransactionStatus @default(DRAFT)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([transactionDate, status])
  @@index([sourceType, sourceId])
  @@index([category, transactionDate])
  @@index([status, transactionDate])
}

/// SEAT-1: one operational seat per `ROLE-1` position key (v1: single fillable slot per position in the tree).
/// Staffing metadata only: does not assign UWR-1 work, does not grant route access, does not run automation.
enum PositionSeatStatus {
  VACANT
  FILLED
  /// Temporary coverage; optional `actingForPositionKey` may name the seat being backfilled.
  ACTING
  /// Co-pilot / trainee: occupant is not the primary owner; still for visibility and training rails only.
  SHADOW
}

model PositionSeat {
  id        String   @id @default(cuid())
  /// Matches `PositionId` string in `src/lib/campaign-engine/positions.ts` (not a Prisma enum — additive).
  positionKey String  @unique
  userId    String?
  user      User?    @relation("PositionSeatOccupant", fields: [userId], references: [id], onDelete: SetNull)
  status    PositionSeatStatus @default(VACANT)
  /// When status is ACTING, optional position key the occupant is covering (e.g. backfill for a vacant sub-seat).
  actingForPositionKey String?
  notes     String?  @db.Text
  /// Optional structured notes (e.g. source of truth ref); no product logic reads this in SEAT-1.
  metadataJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, positionKey])
}

enum EmailOptInStatus {
  UNKNOWN
  OPT_IN
  OPT_OUT
}

enum SmsOptInStatus {
  UNKNOWN
  OPT_IN
  OPT_OUT
}

/// Channel consent and third-party opt-out / suppression (Tier 1 comms workbench).
model ContactPreference {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  volunteerProfileId String?           @unique
  volunteerProfile   VolunteerProfile? @relation(fields: [volunteerProfileId], references: [id], onDelete: SetNull)

  /// Standalone thread (no User/VolunteerProfile) — e.g. SMS-only before resolution.
  communicationThreadId String?              @unique
  thread                CommunicationThread? @relation(fields: [communicationThreadId], references: [id], onDelete: Cascade)

  emailOptInStatus         EmailOptInStatus @default(UNKNOWN)
  smsOptInStatus           SmsOptInStatus   @default(UNKNOWN)
  /// Marketing / bulk email: treat as do-not-mail when set.
  globalUnsubscribeAt      DateTime?
  smsOptOutAt              DateTime?
  /// Raw SendGrid / Twilio / vendor signals for debugging and audits.
  sendgridSuppressionState Json?            @default("{}")
  twilioOptOutState        String?
  source                   String?
  notes                    String?          @db.Text
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
}

model VolunteerProfile {
  id                              String                           @id @default(cuid())
  userId                          String                           @unique
  user                            User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability                    String?
  skills                          String?
  leadershipInterest              Boolean                          @default(false)
  eventSignups                    EventSignup[]
  communicationThreads            CommunicationThread[]
  contactPreference               ContactPreference?
  queueAsTarget                   CommunicationActionQueue[]       @relation("QueueTargetVolunteer")
  communicationCampaignRecipients CommunicationCampaignRecipient[]
  commsPlanAudienceSegmentMembers CommsPlanAudienceSegmentMember[] @relation("CommsPlanSegmentMemberVolunteer")
  communicationRecipients         CommunicationRecipient[]
  emailWorkflowItems              EmailWorkflowItem[]                @relation("EmailWorkflowItemVolunteer")
}

model Commitment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Submission {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String
  content        String   @db.Text
  structuredData Json?
  createdAt      DateTime @default(now())

  /// At most one workflow intake per submission (queue entry for CampaignOS Phase 1).
  workflowIntake WorkflowIntake?
}

// --- CampaignOS Phase 1: unified intake queue (extend; do not replace Submission / events / comms) ---

enum WorkflowIntakeStatus {
  PENDING
  IN_REVIEW
  AWAITING_INFO
  READY_FOR_CALENDAR
  CONVERTED
  DECLINED
  ARCHIVED
}

enum WorkflowActionKind {
  STATUS_CHANGE
  ASSIGNMENT
  NOTE
  DECISION
  EVENT_LINKED
  OTHER
}

enum EventRequestStatus {
  OPEN
  FULFILLED
  CANCELLED
}

/// Lifecycle for analytics-originated recommendations and downstream work / evaluation.
enum AnalyticsRecommendationOutcomeStatus {
  GENERATED
  DRAFT_CREATED
  INTAKE_CREATED
  EXECUTED
  EVALUATED
  DISMISSED
  EXPIRED
}

/// Master queue row for intakes; links optional `Submission` and optional 1:1 `EventRequest`.
model WorkflowIntake {
  id             String               @id @default(cuid())
  /// When created from a public/admin form `Submission` (at most one intake per submission).
  submissionId   String?              @unique
  submission     Submission?          @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  /// Staff or volunteer owner in the work queue.
  assignedUserId String?
  assignedUser   User?                @relation("WorkflowIntakeAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  countyId       String?
  county         County?              @relation(fields: [countyId], references: [id], onDelete: SetNull)
  status         WorkflowIntakeStatus @default(PENDING)
  /// Short label for the queue (e.g. event title or host name).
  title          String?
  /// Origin hint: mirrors `Submission.type` or source system key.
  source         String?
  metadata       Json?                @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  eventRequest                   EventRequest?
  actions                        WorkflowAction[]
  socialContentItems             SocialContentItem[]
  /// Routed from public conversation opportunities (action spine).
  conversationOpportunities      ConversationOpportunity[]       @relation("OppWorkflowIntake")
  /// When this intake was created from social analytics (one-to-one from outcome).
  analyticsRecommendationOutcome AnalyticsRecommendationOutcome?
  /// Comms Workbench plans that cite this intake as their source.
  communicationPlansSourced      CommunicationPlan[]             @relation("CommsPlanSourceIntake")
  mediaOutreachItems             MediaOutreachItem[]             @relation("MediaOutreachSourceIntake")
  emailWorkflowItems             EmailWorkflowItem[]             @relation("EmailWorkflowItemIntake")

  @@index([status, createdAt])
  @@index([assignedUserId, status])
  @@index([countyId, status])
}

/// Scheduling bridge: required parent `WorkflowIntake`, optional `CampaignEvent` once scheduled.
model EventRequest {
  id String @id @default(cuid())

  workflowIntakeId String         @unique
  workflowIntake   WorkflowIntake @relation(fields: [workflowIntakeId], references: [id], onDelete: Cascade)
  /// Set when an existing or new `CampaignEvent` fulfills this request.
  campaignEventId  String?
  campaignEvent    CampaignEvent? @relation(fields: [campaignEventId], references: [id], onDelete: SetNull)

  status EventRequestStatus @default(OPEN)

  requestedStartAt DateTime?
  requestedEndAt   DateTime?
  timezone         String    @default("America/Chicago")
  locationName     String?
  address          String?   @db.Text
  /// Free-form: audience, host needs, special instructions.
  requestDetails   String?   @db.Text
  metadata         Json?     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([campaignEventId])
}

/// Audit / decision log for a `WorkflowIntake`.
model WorkflowAction {
  id String @id @default(cuid())

  workflowIntakeId String
  workflowIntake   WorkflowIntake @relation(fields: [workflowIntakeId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation("WorkflowActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  kind       WorkflowActionKind    @default(OTHER)
  fromStatus WorkflowIntakeStatus?
  toStatus   WorkflowIntakeStatus?
  /// Human-readable decision or note; optional structured data in `metadata`.
  summary    String?               @db.Text
  metadata   Json?                 @default("{}")

  createdAt DateTime @default(now())

  @@index([workflowIntakeId, createdAt])
  @@index([actorUserId, createdAt])
}

// --- CampaignOS Phase 2: Social Workbench (additive; does not replace comms, events, or task engine) ---

/// Posting / asset destination (e.g. campaign X account, official FB page). Distinct from Script 6.5 `ContentPlatform`.
enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  X
  TIKTOK
  YOUTUBE
  BLUESKY
  THREADS
  OTHER
}

/// Lifecycle of a conceptual post or post family (may span many platform variants).
enum SocialContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  ARCHIVED
  CANCELLED
}

/// Per-channel variant state.
enum SocialVariantStatus {
  DRAFT
  READY
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

/// Why this work exists — drives which `WorkflowTemplate` / `sourceTemplateTaskKey` you attach on `CampaignTask`.
enum SocialContentKind {
  EVENT_PROMO
  RAPID_RESPONSE
  POST_EVENT_RECAP
  CLIP_REPURPOSE
  ORGANIC
  OTHER
}

/// Messaging style / tactic for learning (non-negative, trust-oriented set). Distinct from Author Studio "voice" presets.
enum SocialMessageToneMode {
  CALM_CLARIFICATION
  COMMUNITY_STORYTELLING
  FAITH_CENTERED
  ISSUE_EDUCATION
  BOLD_CONTRAST
  INVITATIONAL_CTA
}

/// How the post is framed for learning (distinct from `SocialMessageToneMode` voice). Nullable until staff set.
enum SocialMessageTacticMode {
  NARRATIVE
  ISSUE_BRIEF
  VALUES_STORY
  INVITE_ACTION
  RUMOR_CLARIFY
  OTHER
}

/// Suggested follow-up *shape* (campaign-safe, stored on strategic insight). No outrage lanes.
enum SocialStrategicFollowupType {
  NONE
  GENERAL_ENGAGEMENT
  COUNTY_STORY
  VOLUNTEER_PATHWAY
  CLARIFICATION
  RAPID_RESPONSE
  CLARIFICATION_POST
  COUNTY_VARIANT
  VOLUNTEER_CTA
  EVENT_PROMO
  POST_EVENT_RECAP
  NO_ACTION
}

/// Canonical row for a social post plan (intake- or event-anchored; variants are per platform/account).
model SocialContentItem {
  id String @id @default(cuid())

  /// Optional: created from a `WorkflowIntake` (rapid response, request queue, approvals).
  workflowIntakeId String?
  workflowIntake   WorkflowIntake? @relation(fields: [workflowIntakeId], references: [id], onDelete: SetNull)
  /// Optional: anchor to a calendar event (promo, recap, live coverage).
  campaignEventId  String?
  campaignEvent    CampaignEvent?  @relation(fields: [campaignEventId], references: [id], onDelete: SetNull)

  kind              SocialContentKind        @default(OTHER)
  status            SocialContentStatus      @default(DRAFT)
  /// Classified message tactic for tone / timing learning (optional until staff set).
  messageToneMode   SocialMessageToneMode?
  /// Message framing (story vs explainer vs clarifier, etc.) for analytics. Optional.
  messageTacticMode SocialMessageTacticMode?
  /// Working title in the workbench.
  title             String?
  /// Master or default copy; per-platform may override in `SocialPlatformVariant`.
  bodyCopy          String?                  @db.Text
  /// Hook for assets (e.g. owned media id, Canva link, video asset ref).
  metadata          Json?                    @default("{}")

  createdByUserId String?
  createdByUser   User?   @relation("SocialContentAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  platformVariants                          SocialPlatformVariant[]
  tasks                                     CampaignTask[]
  /// Campaign-owned media (`OwnedMediaAsset`) linked to this work item or to a specific platform variant.
  mediaLibraryRefs                          SocialContentMediaRef[]
  performanceSnapshots                      SocialPerformanceSnapshot[]
  strategicInsight                          SocialContentStrategicInsight?
  /// If this work item was created from a public conversation opportunity.
  conversationOpportunitiesAsSocial         ConversationOpportunity[]        @relation("OppSocialContentItem")
  /// Author Studio — saved compose alternates and applied-master snapshots.
  drafts                                    SocialContentDraft[]
  /// Analytics workbench: recommendations attributed to this work item.
  analyticsRecommendationOutcomesSourced    AnalyticsRecommendationOutcome[] @relation("ArOutcomeSource")
  /// This draft/post was created as a follow-up from an analytics recommendation.
  analyticsRecommendationOutcomeAsCreated   AnalyticsRecommendationOutcome?  @relation("ArOutcomeCreated")
  /// Published (or final) post used to measure an analytics-originated outcome.
  analyticsRecommendationOutcomesAsExecuted AnalyticsRecommendationOutcome[] @relation("ArOutcomeExecuted")
  /// Comms Workbench plans that cite this social item as their source.
  communicationPlansSourced                 CommunicationPlan[]              @relation("CommsPlanSourceSocial")
  emailWorkflowItems                        EmailWorkflowItem[]                @relation("EmailWorkflowItemSocial")

  @@index([workflowIntakeId, status])
  @@index([campaignEventId, status])
  @@index([status, kind, createdAt])
  @@index([messageToneMode, kind, updatedAt])
  @@index([messageTacticMode, kind, updatedAt])
  @@index([createdByUserId])
}

/// Durable record for a single analytics recommendation instance, linked artifacts, and optional evaluation.
model AnalyticsRecommendationOutcome {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source             String @default("analytics")
  recommendationType String
  headline           String @db.Text
  confidence         Float?
  heuristicVersion   String @default("v1")

  status AnalyticsRecommendationOutcomeStatus @default(GENERATED)

  dateRangeStart DateTime
  dateRangeEnd   DateTime

  platform    SocialPlatform?
  contentKind SocialContentKind?
  toneMode    SocialMessageToneMode?
  eventId     String?

  sourceSocialContentItemId String?
  sourceSocialContentItem   SocialContentItem? @relation("ArOutcomeSource", fields: [sourceSocialContentItemId], references: [id], onDelete: SetNull)

  provenanceJson Json @default("{}")

  createdSocialContentItemId String?            @unique
  createdSocialContentItem   SocialContentItem? @relation("ArOutcomeCreated", fields: [createdSocialContentItemId], references: [id], onDelete: SetNull)

  createdWorkflowIntakeId String?         @unique
  createdWorkflowIntake   WorkflowIntake? @relation(fields: [createdWorkflowIntakeId], references: [id], onDelete: SetNull)

  executedSocialContentItemId String?
  executedSocialContentItem   SocialContentItem? @relation("ArOutcomeExecuted", fields: [executedSocialContentItemId], references: [id], onDelete: SetNull)

  evaluatedAt DateTime?
  outcomeJson Json?
  notes       String?   @db.Text

  @@index([sourceSocialContentItemId, createdAt])
  @@index([status, createdAt])
  @@index([recommendationType, createdAt])
}

/// Saved Author Studio compose output for a work item (reuse, audit, optional “applied” marker).
model SocialContentDraft {
  id                  String            @id @default(cuid())
  socialContentItemId String
  socialContentItem   SocialContentItem @relation(fields: [socialContentItemId], references: [id], onDelete: Cascade)
  title               String?
  sourceRoute         String?
  sourceIntent        String?
  bodyCopy            String            @db.Text
  createdByUserId     String?
  createdByUser       User?             @relation("SocialContentDraftAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  isApplied           Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([socialContentItemId, createdAt])
  @@index([createdByUserId])
}

/// A single channel-specific slice of a `SocialContentItem` (copy, schedule, post id when published).
model SocialPlatformVariant {
  id String @id @default(cuid())

  socialContentItemId String
  socialContentItem   SocialContentItem @relation(fields: [socialContentItemId], references: [id], onDelete: Cascade)
  /// Optional: target account; when null, `platform` still identifies intended network for drafts.
  socialAccountId     String?
  socialAccount       SocialAccount?    @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)
  platform            SocialPlatform

  status         SocialVariantStatus @default(DRAFT)
  /// Per-channel copy, thread text, or caption.
  copyText       String?             @db.Text
  /// Planned send time (staff timezone or UTC per product convention).
  scheduledAt    DateTime?
  publishedAt    DateTime?
  /// External id when published (API scope — engagement ingestion is Phase+ later).
  externalPostId String?
  metadata       Json?               @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mediaLibraryRefs     SocialContentMediaRef[]
  performanceSnapshots SocialPerformanceSnapshot[]

  @@index([socialContentItemId, platform])
  @@index([status, scheduledAt])
  @@index([socialAccountId, status])
  @@index([platform, status])
}

/// Audience / thread classification for learning (trust-building, not pile-ons).
enum SocialSentimentType {
  SUPPORTER
  CURIOUS
  SKEPTICAL
  CONFUSED
  HOSTILE
  MEDIA
  UNKNOWN
}

enum SocialPerformanceDataSource {
  MANUAL
  API_IMPORT
  ESTIMATE
  AGGREGATOR
}

/// Time-bucketed performance for a work item (whole-item or per-platform variant). Meaningful rates over raw vanity totals.
model SocialPerformanceSnapshot {
  id String @id @default(cuid())

  socialContentItemId     String
  socialContentItem       SocialContentItem      @relation(fields: [socialContentItemId], references: [id], onDelete: Cascade)
  /// Null = rollup across all variants; set for per-channel cut.
  socialPlatformVariantId String?
  socialPlatformVariant   SocialPlatformVariant? @relation(fields: [socialPlatformVariantId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  impressions         Int?
  likes               Int?
  comments            Int?
  shares              Int?
  saves               Int?
  /// Outbound or tracked link clicks (platform-dependent).
  clickThroughs       Int?
  /// CTR 0–1 when impressions known; optional if only clicks available.
  clickThroughRate    Float?
  /// Watch-through for video, 0–1.
  videoCompletionRate Float?

  /// Composite “meaningful engagement” 0–100 (staff or model-defined formula).
  engagementQualityScore    Float?
  /// Rough mix of thread tone for this period.
  dominantSentiment         SocialSentimentType?
  /// Counts by `SocialSentimentType`, e.g. { "SUPPORTER": 12, "CURIOUS": 3 }.
  sentimentBreakdownJson    Json?                @default("{}")
  /// Optional tie for conversion story (e.g. event promo → signups).
  conversionCampaignEventId String?
  conversionCampaignEvent   CampaignEvent?       @relation("SocialSnapshotConversion", fields: [conversionCampaignEventId], references: [id], onDelete: SetNull)
  /// Soft signal: volunteer / interest DMs (manual or CRM hook).
  volunteerLeadCount        Int?

  dataSource SocialPerformanceDataSource @default(MANUAL)
  /// Staff / importer notes; not a chart title.
  notes      String?                     @db.Text
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  @@index([socialContentItemId, periodStart])
  @@index([socialPlatformVariantId, periodStart])
  @@index([conversionCampaignEventId])
}

/// One insight row per work item: strategic narrative + AI placeholders (no generic dashboard).
model SocialContentStrategicInsight {
  id                  String            @id @default(cuid())
  /// 1:1 with work item
  socialContentItemId String            @unique
  socialContentItem   SocialContentItem @relation(fields: [socialContentItemId], references: [id], onDelete: Cascade)

  /// Best windows observed / hypothesized (local time notes).
  timingInsight    String? @db.Text
  /// Which voice / tone over-indexed for trust and replies.
  tonePerformance  String? @db.Text
  /// Saves, replays, thread depth — what helps people stay with the message.
  retentionSignal  String? @db.Text
  /// RSVPs, volunteer taps, `CampaignEvent` links when set on snapshots.
  conversionSignal String? @db.Text

  /// TODO: call OpenAI / moderation to classify recent comments; store summary here.
  aiCommentClassifyStub      String?   @db.Text
  /// TODO: summarize this item’s performance vs goals.
  aiSummarizePerformanceStub String?   @db.Text
  /// TODO: next experiments / copy tweaks.
  aiSuggestImprovementsStub  String?   @db.Text
  lastAiRunAt                DateTime?

  /// Actionable, structured recommendations (0–1 confidence). Narrative text remains in the four `*Insight` fields above.
  recommendedNextTone     SocialMessageToneMode?
  recommendedBestWindow   String?                     @db.Text
  recommendedFollowupType SocialStrategicFollowupType @default(NONE)
  /// Freeform county or region label when follow-up is county-scoped; optional `County` FK in a later pass.
  recommendedCountyFocus  String?                     @db.Text
  /// Short label, e.g. "reply", "link_in_bio", "rsvp" — keep human-readable.
  recommendedCtaType      String?                     @db.Text
  /// Model / heuristic confidence in the block above, 0–1.
  confidenceScore         Float?

  updatedAt DateTime @updatedAt
}

// --- Public conversation monitoring (signals, not individuals — no PII vault) ---

/// Where a normalized `ConversationItem` was observed (public sources only).
enum ConversationSourceKind {
  SOCIAL_PLATFORM
  NEWS_SITE
  RSS
  PRESS_RELEASE
  MANUAL_ENTRY
  API_IMPORT
}

/// Coarse actor boundary for public signal (not used to track private people).
enum ConversationSignalActorType {
  OFFICIAL_ORG
  PRESS
  ELECTED_OR_COMMENTARY
  COMMUNITY_THREAD
  UNKNOWN
}

enum ConversationItemStatus {
  NEW
  ENRICHED
  CLUSTERED
  DISMISSED
  ARCHIVED
}

enum ConversationClassification {
  ISSUE_ECONOMY
  ISSUE_HEALTH
  ISSUE_EDUCATION
  ISSUE_INFRA
  ISSUE_VOTING
  ISSUE_LOCAL
  MISINFO_RISK
  QUESTION
  SUPPORT
  CRITIQUE
  NEUTRAL_REPORT
  OTHER
  UNKNOWN
}

enum ConversationSentimentLabel {
  POSITIVE
  NEUTRAL
  MIXED
  NEGATIVE
  UNKNOWN
}

enum ConversationUrgency {
  LOW
  MEDIUM
  HIGH
  BREAKING
}

enum ConversationSuggestedTone {
  CALM
  FACTUAL
  EMPATHETIC
  FIRM
  CELEBRATORY
  DEFERRING
  OTHER
}

enum ConversationWatchlistStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ConversationClusterStatus {
  ACTIVE
  MERGED
  ARCHIVED
}

enum ConversationOpportunityStatus {
  OPEN
  ROUTED
  CONVERTED
  DISMISSED
}

/// Named filter set for public-source monitoring (keywords, channels — no individual targets).
model ConversationWatchlist {
  id              String                      @id @default(cuid())
  name            String
  description     String?                     @db.Text
  status          ConversationWatchlistStatus @default(ACTIVE)
  /// JSON: keyword groups, allowed channels, hashtags, etc.
  filterSpec      Json                        @default("{}")
  countyId        String?
  county          County?                     @relation(fields: [countyId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       User?                       @relation("WatchlistCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  items ConversationItem[]

  @@index([countyId, status])
  @@index([status, updatedAt])
}

/// One normalized public post, comment thread, or article (aggregated content; no private DMs).
model ConversationItem {
  id              String                      @id @default(cuid())
  sourceKind      ConversationSourceKind
  /// Adapter idempotency key (post id, URL hash, etc.); optional for one-off manual rows.
  externalKey     String?
  publicPermalink String?                     @db.Text
  channel         String
  title           String?
  bodyText        String                      @db.Text
  signalActorType ConversationSignalActorType @default(UNKNOWN)
  publishedAt     DateTime?
  countyId        String?
  county          County?                     @relation(fields: [countyId], references: [id], onDelete: SetNull)
  watchlistId     String?
  watchlist       ConversationWatchlist?      @relation(fields: [watchlistId], references: [id], onDelete: SetNull)
  status          ConversationItemStatus      @default(NEW)
  /// Ingest metadata (API version, search id) — must not store PII.
  rawMetadata     Json?                       @default("{}")
  ingestedAt      DateTime                    @default(now())
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  analysis             ConversationAnalysis?
  clusterMemberships   ConversationClusterItem[]
  opportunityAsPrimary ConversationOpportunity?  @relation("OppPrimaryItem")

  @@unique([sourceKind, externalKey])
  @@index([sourceKind, publishedAt])
  @@index([countyId, status])
  @@index([status, createdAt])
  @@index([watchlistId, createdAt])
}

/// AI / rules enrichment for a `ConversationItem` (latest analysis; re-run overwrites).
model ConversationAnalysis {
  id                 String           @id @default(cuid())
  conversationItemId String           @unique
  conversationItem   ConversationItem @relation(fields: [conversationItemId], references: [id], onDelete: Cascade)

  summary             String?                    @db.Text
  classification      ConversationClassification @default(UNKNOWN)
  sentiment           ConversationSentimentLabel @default(UNKNOWN)
  urgency             ConversationUrgency        @default(MEDIUM)
  suggestedTone       ConversationSuggestedTone  @default(FACTUAL)
  issueTags           String[]                   @default([])
  countyInferenceNote String?                    @db.Text
  suggestedAction     String?                    @db.Text
  confidenceJson      Json?                      @default("{}")
  analyzerVersion     String?
  analyzedAt          DateTime                   @default(now())
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([classification, urgency])
  @@index([analyzedAt])
}

/// Correlation group for similar public signals (e.g. same misinfo wave).
model ConversationCluster {
  id         String                    @id @default(cuid())
  title      String
  summary    String?                   @db.Text
  status     ConversationClusterStatus @default(ACTIVE)
  /// Optional dedupe / embedding key (future).
  clusterKey String?
  countyId   String?
  county     County?                   @relation(fields: [countyId], references: [id], onDelete: SetNull)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  items         ConversationClusterItem[]
  opportunities ConversationOpportunity[]

  @@index([countyId, status])
  @@index([status, updatedAt])
}

/// Bridge: which items belong to a cluster and how strongly.
model ConversationClusterItem {
  id                 String              @id @default(cuid())
  clusterId          String
  cluster            ConversationCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  conversationItemId String
  conversationItem   ConversationItem    @relation(fields: [conversationItemId], references: [id], onDelete: Cascade)
  similarity         Float?
  addedAt            DateTime            @default(now())

  @@unique([clusterId, conversationItemId])
  @@index([conversationItemId])
}

/// Actionable “response opportunity” — can route to `WorkflowIntake` and/or `SocialContentItem`.
model ConversationOpportunity {
  id                        String                        @id @default(cuid())
  title                     String
  summary                   String?                       @db.Text
  status                    ConversationOpportunityStatus @default(OPEN)
  urgency                   ConversationUrgency           @default(MEDIUM)
  suggestedTone             ConversationSuggestedTone     @default(FACTUAL)
  /// Intent for CampaignOS: RAPID_RESPONSE, CLARIFICATION, FAQ, BRIEF_NOTE, etc.
  actionTemplate            String?
  countyId                  String?
  county                    County?                       @relation(fields: [countyId], references: [id], onDelete: SetNull)
  /// Primary signal this opportunity was created from.
  primaryConversationItemId String?                       @unique
  primaryItem               ConversationItem?             @relation("OppPrimaryItem", fields: [primaryConversationItemId], references: [id], onDelete: SetNull)
  clusterId                 String?
  cluster                   ConversationCluster?          @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  workflowIntakeId          String?
  workflowIntake            WorkflowIntake?               @relation("OppWorkflowIntake", fields: [workflowIntakeId], references: [id], onDelete: SetNull)
  socialContentItemId       String?
  socialContentItem         SocialContentItem?            @relation("OppSocialContentItem", fields: [socialContentItemId], references: [id], onDelete: SetNull)
  createdByUserId           String?
  createdBy                 User?                         @relation("OpportunityCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  metadata                  Json?                         @default("{}")
  convertedAt               DateTime?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  mediaOutreachItems        MediaOutreachItem[]           @relation("MediaOutreachSourceOpp")
  emailWorkflowItems        EmailWorkflowItem[]            @relation("EmailWorkflowItemOpp")

  @@index([status, urgency])
  @@index([countyId, status])
  @@index([workflowIntakeId])
  @@index([socialContentItemId])
  @@index([clusterId])
}

/// Why a piece of `OwnedMediaAsset` is associated with a social work item.
enum SocialContentMediaRefPurpose {
  /// General planning / library attachment on the work item.
  SOCIAL_PLAN
  /// Candidate source for repurpose (video) workflows — TODO: timecodes + clip index.
  VIDEO_REPURPOSE
  /// Image/graphic/quote workflow input — TODO: crop / template ids.
  VISUAL
  /// Pin to a specific `SocialPlatformVariant` (e.g. Reels vs Shorts).
  PLATFORM_VARIANT
}

/// Join table: `OwnedMediaAsset` ↔ social workbench without duplicating file rows.
model SocialContentMediaRef {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedMediaId String
  ownedMedia   OwnedMediaAsset @relation(fields: [ownedMediaId], references: [id], onDelete: Cascade)

  socialContentItemId String
  socialContentItem   SocialContentItem @relation(fields: [socialContentItemId], references: [id], onDelete: Cascade)

  /// When set, asset is associated with a specific cut of this item (e.g. Instagram vs X).
  socialPlatformVariantId String?
  socialPlatformVariant   SocialPlatformVariant? @relation(fields: [socialPlatformVariantId], references: [id], onDelete: SetNull)

  purpose   SocialContentMediaRefPurpose
  /// Optional staff context (e.g. “8–22s b-roll”); structured clip refs stay TODO for AI.
  note      String?                      @db.Text
  sortOrder Int                          @default(0)

  createdByUserId String?
  createdBy       User?   @relation("SocialMediaRefCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([socialContentItemId, purpose, sortOrder])
  @@index([ownedMediaId])
  @@index([socialPlatformVariantId])
  @@index([createdAt])
}

/// Registered outbound identity for the campaign (one row per account/handle you manage).
model SocialAccount {
  id         String         @id @default(cuid())
  platform   SocialPlatform
  label      String
  /// Handle without @, or page name slug as stored by staff.
  handle     String?
  /// Vendor / network page id, useful when wiring APIs.
  externalId String?
  profileUrl String?
  isActive   Boolean        @default(true)
  notes      String?        @db.Text
  metadata   Json?          @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants SocialPlatformVariant[]

  @@index([platform, isActive])
  @@index([handle, platform])
}

model SearchChunk {
  id         String   @id @default(cuid())
  path       String
  title      String?
  chunkIndex Int
  content    String   @db.Text
  embedding  String   @db.Text
  createdAt  DateTime @default(now())

  @@unique([path, chunkIndex])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  payload   Json?
  path      String?
  sessionId String?
  createdAt DateTime @default(now())
}


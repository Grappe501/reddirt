  /// E-1: email workflow items referencing this plan.
  emailWorkflowItems        EmailWorkflowItem[]         @relation("EmailWorkflowItemPlan")

  @@index([status, updatedAt])
  @@index([objective, status])
  @@index([scheduledAt])
  @@index([ownerUserId])
  @@index([status, scheduledAt])
  @@index([sourceWorkflowIntakeId])
  @@index([sourceCampaignTaskId])
  @@index([sourceEventId])
  @@index([sourceSocialContentItemId])
}

model CommunicationDraft {
  id                      String                       @id @default(cuid())
  communicationPlanId     String
  plan                    CommunicationPlan            @relation(fields: [communicationPlanId], references: [id], onDelete: Cascade)
  channel                 CommsWorkbenchChannel
  title                   String?
  subjectLine             String?                      @db.Text
  previewText             String?                      @db.Text
  bodyCopy                String                       @default("") @db.Text
  shortCopy               String?                      @db.Text
  /// Aligns with Social / Author learning dimensions where applicable.
  messageToneMode         SocialMessageToneMode?
  messageTacticMode       SocialMessageTacticMode?
  ctaType                 String?
  status                  CommunicationDraftStatus     @default(DRAFT)
  createdByUserId         String?
  createdByUser           User?                        @relation("CommsDraftCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId         String?
  updatedByUser           User?                        @relation("CommsDraftUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  isPrimary               Boolean                      @default(false)
  reviewRequestedAt       DateTime?
  reviewRequestedByUserId String?
  reviewRequestedByUser   User?                        @relation("CommsDraftReviewRequester", fields: [reviewRequestedByUserId], references: [id], onDelete: SetNull)
  reviewedAt              DateTime?
  reviewedByUserId        String?
  reviewedByUser          User?                        @relation("CommsDraftReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewDecision          CommunicationReviewDecision?
  reviewNotes             String?                      @db.Text
  metadataJson            Json                         @default("{}")
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  variants CommunicationVariant[]
  sends    CommunicationSend[]

  @@index([communicationPlanId])
  @@index([status])
  @@index([channel])
  @@index([isPrimary])
  @@index([messageToneMode])
  @@index([messageTacticMode])
}

model CommunicationVariant {
  id                      String                       @id @default(cuid())
  communicationDraftId    String
  draft                   CommunicationDraft           @relation(fields: [communicationDraftId], references: [id], onDelete: Cascade)
  variantType             CommunicationVariantType     @default(OTHER)
  /// Opaque id or external segment key; no CRM engine integration in this packet.
  targetSegmentId         String?
  targetSegmentLabel      String?
  channelOverride         CommsWorkbenchChannel?
  subjectLineOverride     String?                      @db.Text
  bodyCopyOverride        String?                      @db.Text
  ctaOverride             String?                      @db.Text
  status                  CommunicationVariantStatus   @default(DRAFT)
  reviewRequestedAt       DateTime?
  reviewRequestedByUserId String?
  reviewRequestedByUser   User?                        @relation("CommsVariantReviewRequester", fields: [reviewRequestedByUserId], references: [id], onDelete: SetNull)
  reviewedAt              DateTime?
  reviewedByUserId        String?
  reviewedByUser          User?                        @relation("CommsVariantReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewDecision          CommunicationReviewDecision?
  reviewNotes             String?                      @db.Text
  metadataJson            Json                         @default("{}")
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  sends CommunicationSend[]

  @@index([communicationDraftId])
  @@index([targetSegmentId])
  @@index([status])
  @@index([reviewRequestedByUserId])
  @@index([reviewedByUserId])
}

model CommunicationSend {
  id                           String                        @id @default(cuid())
  communicationPlanId          String
  plan                         CommunicationPlan             @relation(fields: [communicationPlanId], references: [id], onDelete: Cascade)
  communicationDraftId         String
  draft                        CommunicationDraft            @relation(fields: [communicationDraftId], references: [id], onDelete: Cascade)
  communicationVariantId       String?
  variant                      CommunicationVariant?         @relation(fields: [communicationVariantId], references: [id], onDelete: SetNull)
  channel                      CommsWorkbenchChannel
  sendType                     CommunicationSendType?
  /// Opaque segment reference for targeting traceability; no engine in this packet.
  targetSegmentId              String?
  status                       CommunicationSendStatus       @default(DRAFT)
  scheduledAt                  DateTime?
  /// Set when an operator queues the send for execution (handoff intent; no worker in Packet 9).
  queuedAt                     DateTime?
  queuedByUserId               String?
  queuedByUser                 User?                         @relation("CommsSendQueuedBy", fields: [queuedByUserId], references: [id], onDelete: SetNull)
  sentAt                       DateTime?
  completedAt                  DateTime?
  sentByUserId                 String?
  sentByUser                   User?                         @relation("CommsSendSender", fields: [sentByUserId], references: [id], onDelete: SetNull)
  outcomeSummaryJson           Json?
  /// Reserved for future provider reconciliation; no integration in this packet.
  providerMessageId            String?
  /// Operator retry re-queues after FAILED (Packet 12A). Counts re-queue events, not the first execution.
  retryCount                   Int                           @default(0)
  lastRetriedAt                DateTime?
  lastRetriedByUserId          String?
  lastRetriedByUser            User?                         @relation("CommsSendLastRetriedBy", fields: [lastRetriedByUserId], references: [id], onDelete: SetNull)
  metadataJson                 Json                          @default("{}")
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  /// One row per targeted contact/address for this send; normalized engagement lives in `CommunicationRecipientEvent`.
  communicationRecipients      CommunicationRecipient[]
  communicationLinkDefinitions CommunicationLinkDefinition[]
  /// E-1: optional link from queue item to a workbench send.
  emailWorkflowItems           EmailWorkflowItem[]              @relation("EmailWorkflowItemSend")

  @@index([communicationPlanId])
  @@index([communicationDraftId])
  @@index([communicationVariantId])
  @@index([status])
  @@index([scheduledAt])
  @@index([channel])
  @@index([queuedByUserId])
  @@index([providerMessageId])
  @@index([lastRetriedByUserId])
}

// --- Email Workflow Intelligence (E-1+): campaign email ops queue; queue-first, no auto-send/approval in E-1. ---

enum EmailWorkflowStatus {
  NEW
  /// E-2A: deterministic interpretation completed; item still queue-first (not approved or sent).
  ENRICHED
  IN_REVIEW
  READY_TO_RESPOND
  APPROVED
  ESCALATED
  SPAM
  CLOSED
  ARCHIVED
}

enum EmailWorkflowPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EmailWorkflowSourceType {
  INBOUND_EMAIL
  OUTBOUND_FOLLOWUP
  WORKFLOW_TRIGGER
  SEGMENT_TRIGGER
  VOLUNTEER_TRIGGER
  EVENT_TRIGGER
  MANUAL
  OTHER
}

enum EmailWorkflowTriggerType {
  MANUAL
  INBOUND_MESSAGE
  OUTBOUND_DRAFT
  SCHEDULED
  MONITORING
  INTAKE
  OTHER
}

enum EmailWorkflowIntent {
  QUESTION

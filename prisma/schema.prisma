}

/// One queued email-related workflow unit (context-rich; operator review before any send — E-1 default).
model EmailWorkflowItem {
  id     String @id @default(cuid())
  /// Queue-first: new items are never auto-approved or auto-sent (policy comes in later packets).
  status EmailWorkflowStatus @default(NEW)
  /// Priority for triage; does not bypass review in E-1.
  priority EmailWorkflowPriority @default(NORMAL)

  sourceType  EmailWorkflowSourceType  @default(MANUAL)
  triggerType EmailWorkflowTriggerType @default(MANUAL)

  /// Optional short list label.
  title       String? @db.VarChar(500)
  queueReason String? @db.Text

  whoSummary   String? @db.Text
  whatSummary  String? @db.Text
  whenSummary  String? @db.Text
  whereSummary String? @db.Text
  whySummary   String? @db.Text
  /// Campaign / program impact.
  impactSummary                String? @db.Text
  recommendedResponseSummary   String? @db.Text
  recommendedResponseRationale String? @db.Text

  /// Freeform classifier until E-2+ structured sentiment.
  sentiment String? @db.VarChar(120)

  tone              EmailWorkflowTone                 @default(UNKNOWN)
  intent            EmailWorkflowIntent               @default(UNKNOWN)
  escalationLevel   EmailWorkflowEscalationLevel      @default(NONE)
  spamDisposition   EmailWorkflowSpamDisposition      @default(UNKNOWN)
  /// Placeholder 0..1; automation deferred.
  spamScore         Float?
  needsDeescalation Boolean @default(false)

  /// Optional machine time for sorting (e.g. inbound time); `whenSummary` is operator-facing.
  occurredAt DateTime?

  userId            String?
  user              User?   @relation("EmailWorkflowItemContactUser", fields: [userId], references: [id], onDelete: SetNull)
  volunteerProfileId String?
  volunteerProfile  VolunteerProfile? @relation("EmailWorkflowItemVolunteer", fields: [volunteerProfileId], references: [id], onDelete: SetNull)
  communicationThreadId String?
  thread            CommunicationThread? @relation("EmailWorkflowItemThread", fields: [communicationThreadId], references: [id], onDelete: SetNull)
  communicationPlanId  String?
  plan                 CommunicationPlan?  @relation("EmailWorkflowItemPlan", fields: [communicationPlanId], references: [id], onDelete: SetNull)
  communicationSendId  String?
  send                 CommunicationSend?  @relation("EmailWorkflowItemSend", fields: [communicationSendId], references: [id], onDelete: SetNull)
  workflowIntakeId     String?
  workflowIntake      WorkflowIntake? @relation("EmailWorkflowItemIntake", fields: [workflowIntakeId], references: [id], onDelete: SetNull)
  campaignTaskId      String?
  campaignTask        CampaignTask? @relation("EmailWorkflowItemTask", fields: [campaignTaskId], references: [id], onDelete: SetNull)
  conversationOpportunityId String?
  conversationOpportunity  ConversationOpportunity? @relation("EmailWorkflowItemOpp", fields: [conversationOpportunityId], references: [id], onDelete: SetNull)
  socialContentItemId  String?
  socialContentItem    SocialContentItem? @relation("EmailWorkflowItemSocial", fields: [socialContentItemId], references: [id], onDelete: SetNull)
  comsPlanAudienceSegmentId String?
  comsPlanAudienceSegment   CommsPlanAudienceSegment? @relation("EmailWorkflowItemSegment", fields: [comsPlanAudienceSegmentId], references: [id], onDelete: SetNull)
  communicationMessageId String?
  communicationMessage  CommunicationMessage? @relation("EmailWorkflowItemMessage", fields: [communicationMessageId], references: [id], onDelete: SetNull)

  assignedToUserId  String?
  assignedToUser    User?   @relation("EmailWorkflowItemAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdByUserId   String?
  createdBy         User?   @relation("EmailWorkflowItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedByUserId String?
  reviewedBy         User?   @relation("EmailWorkflowItemReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt         DateTime?

  metadataJson Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority, createdAt])
  @@index([assignedToUserId, status])
  @@index([sourceType, status])
  @@index([communicationThreadId])
  @@index([communicationPlanId])
  @@index([escalationLevel, status])
  @@index([spamDisposition, status])
  @@index([createdAt])
}

// --- Contact engagement + segmentation (Comms workbench, campaign-local; CE-1) ---
// `CommunicationSend` is the message-level object; `CommunicationRecipient` is the per-recipient bridge.
// Distinct from Tier 2 `AudienceSegment` / `CommunicationCampaign` broadcast segments.

/// Lifecycle of a recipient row for a workbench send (aggregated/rolled up from events over time).
enum CommunicationRecipientStatus {
  PLANNED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  FAILED
  BOUNCED
  UNSUBSCRIBED
  CANCELED
}

/// Normalized engagement and bridge events (provider + future web/landing; CE-3+ ingestion).
enum CommunicationRecipientEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  FAILED
  BOUNCED
  UNSUBSCRIBED
  OPTED_OUT_SMS
  WEB_VISIT
  FORM_SUBMITTED
}

/// Best-known delivery state for a recipient row (recomputed from events + consent where applicable).
enum CommsDeliveryHealthStatus {
  HEALTHY
  SUPPRESSED
  UNSUBSCRIBED
  INVALID_EMAIL
  INVALID_PHONE
  HARD_BOUNCED
  SMS_OPT_OUT
  UNKNOWN
}

enum CommsPlanAudienceSegmentType {
  STATIC
  DYNAMIC
  SYSTEM
}

enum CommsPlanAudienceSegmentStatus {
  ACTIVE
  ARCHIVED
}

enum CommsPlanAudienceSegmentMemberSource {
  MANUAL
  IMPORT
  DYNAMIC_SNAPSHOT
  API
  OTHER
}

model CommunicationRecipient {
  id                        String                       @id @default(cuid())
  communicationSendId       String
  send                      CommunicationSend            @relation(fields: [communicationSendId], references: [id], onDelete: Cascade)
  /// Optional link to a message-plan audience segment (CE-6+); null when not segment-targeted.
  comsPlanAudienceSegmentId String?
  comsPlanAudienceSegment   CommsPlanAudienceSegment?    @relation(fields: [comsPlanAudienceSegmentId], references: [id], onDelete: SetNull)
  channel                   CommsWorkbenchChannel
  /// Normalized address used for this attempt (email, E.164 phone, or opaque id if stored that way).
  addressUsed               String
  /// Opaque contact key (external/CRM-scoped string). Use when no `User`/`VolunteerProfile`/thread row applies yet.
  crmContactKey             String?
  userId                    String?
  user                      User?                        @relation("CommunicationRecipientUser", fields: [userId], references: [id], onDelete: SetNull)
  volunteerProfileId        String?
  volunteerProfile          VolunteerProfile?            @relation(fields: [volunteerProfileId], references: [id], onDelete: SetNull)
  communicationThreadId     String?
  thread                    CommunicationThread?         @relation("WorkbenchRecipientThread", fields: [communicationThreadId], references: [id], onDelete: SetNull)
  /// Echo of send-level segment hint for traceability.
  targetSegmentId           String?
  targetSegmentLabel        String?
  status                    CommunicationRecipientStatus @default(PLANNED)
  providerRecipientId       String?
  deliveryHealthStatus      CommsDeliveryHealthStatus    @default(UNKNOWN)
  metadataJson              Json                         @default("{}")
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  events CommunicationRecipientEvent[]

  @@index([communicationSendId])
  @@index([comsPlanAudienceSegmentId])
  @@index([userId])
  @@index([volunteerProfileId])
  @@index([communicationThreadId])
  @@index([status, updatedAt])
  @@index([crmContactKey])
  @@index([deliveryHealthStatus])
  @@index([targetSegmentId])
  /// CE-3: one workbench target per send+channel+normalized address (no duplicate expansion rows).
  @@unique([communicationSendId, channel, addressUsed])
}

model CommunicationRecipientEvent {
  id                       String                          @id @default(cuid())
  communicationRecipientId String
  recipient                CommunicationRecipient          @relation(fields: [communicationRecipientId], references: [id], onDelete: Cascade)
  eventType                CommunicationRecipientEventType
  occurredAt               DateTime
  providerEventId          String?
  providerName             String?
  linkUrl                  String?                         @db.Text
  linkLabel                String?
  metadataJson             Json                            @default("{}")
  createdAt                DateTime                        @default(now())

  @@index([communicationRecipientId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([providerEventId])
}

/// Tracked link on a workbench send (click bridge; optional in CE-1, used by CE-3+ / CE-8).
model CommunicationLinkDefinition {
  id                  String            @id @default(cuid())
  communicationSendId String
  send                CommunicationSend @relation(fields: [communicationSendId], references: [id], onDelete: Cascade)
  label               String
  url                 String            @db.Text
  /// Stable id for click correlation (query param or provider token).
  trackingKey         String
  createdAt           DateTime          @default(now())

  @@unique([communicationSendId, trackingKey])
  @@index([communicationSendId])
}

/// Reusable group within a single message plan (distinct from broadcast `AudienceSegment`).
model CommsPlanAudienceSegment {
  id                  String                         @id @default(cuid())
  communicationPlanId String
  plan                CommunicationPlan              @relation(fields: [communicationPlanId], references: [id], onDelete: Cascade)
  name                String
  description         String?                        @db.Text
  segmentType         CommsPlanAudienceSegmentType   @default(STATIC)
  status              CommsPlanAudienceSegmentStatus @default(ACTIVE)
  /// Dynamic rule payload (CE-4+); for STATIC segments may store hints or match keys.
  ruleDefinitionJson  Json                           @default("{}")
  isDynamic           Boolean                        @default(false)
  createdByUserId     String?
  createdBy           User?                          @relation("CommsPlanSegmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId     String?
  updatedBy           User?                          @relation("CommsPlanSegmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  members                 CommsPlanAudienceSegmentMember[]
  communicationRecipients CommunicationRecipient[]
  emailWorkflowItems      EmailWorkflowItem[]         @relation("EmailWorkflowItemSegment")

  @@index([communicationPlanId])
  @@index([status])
  @@index([segmentType])
  @@index([isDynamic])
  @@index([name])
  @@index([createdByUserId])
}

model CommsPlanAudienceSegmentMember {
  id                        String                               @id @default(cuid())
  comsPlanAudienceSegmentId String
  segment                   CommsPlanAudienceSegment             @relation(fields: [comsPlanAudienceSegmentId], references: [id], onDelete: Cascade)
  /// At least one identity field should be set (enforced in application / later CHECK).
  userId                    String?
  user                      User?                                @relation("CommsPlanSegmentMemberSubject", fields: [userId], references: [id], onDelete: Cascade)
  volunteerProfileId        String?
  segmentVolunteerProfile   VolunteerProfile?                    @relation("CommsPlanSegmentMemberVolunteer", fields: [volunteerProfileId], references: [id], onDelete: Cascade)
  crmContactKey             String?
  sourceType                CommsPlanAudienceSegmentMemberSource @default(MANUAL)
  addedByUserId             String?
  addedBy                   User?                                @relation("CommsPlanSegmentMemberAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                             @default(now())

  /// One membership row per segment per user when `userId` is set (NULL userId allowed for crm-only rows).
  @@unique([comsPlanAudienceSegmentId, userId])
  @@index([comsPlanAudienceSegmentId])
  @@index([userId])
  @@index([volunteerProfileId])
  @@index([crmContactKey])
}

model MediaOutreachItem {
  id                              String                   @id @default(cuid())
  type                            MediaOutreachItemType
  title                           String
  contactName                     String?
  outletName                      String?
  status                          MediaOutreachStatus      @default(NEW)
  /// Reuse conversation monitoring urgency scale for ops consistency.
  urgency                         ConversationUrgency?
  linkedCommunicationPlanId       String?
  linkedCommunicationPlan         CommunicationPlan?       @relation(fields: [linkedCommunicationPlanId], references: [id], onDelete: SetNull)
  linkedWorkflowIntakeId          String?
  linkedWorkflowIntake            WorkflowIntake?          @relation("MediaOutreachSourceIntake", fields: [linkedWorkflowIntakeId], references: [id], onDelete: SetNull)
  linkedConversationOpportunityId String?
  linkedConversationOpportunity   ConversationOpportunity? @relation("MediaOutreachSourceOpp", fields: [linkedConversationOpportunityId], references: [id], onDelete: SetNull)
  notes                           String?                  @db.Text
  metadataJson                    Json                     @default("{}")
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt

  @@index([status, updatedAt])
  @@index([type, status])
  @@index([linkedCommunicationPlanId])
  @@index([linkedWorkflowIntakeId])
  @@index([linkedConversationOpportunityId])
  @@index([updatedAt])
}

/// OAuth-linked Google mailbox for 1:1 human email from the workbench (Gmail API). Not used for SendGrid broadcast.
model StaffGmailAccount {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Workspace / Gmail “send as” address (usually same as `User.email`).
  sendAsEmail String
  oauthJson   Json     @default("{}")
  isActive    Boolean  @default(true)
  lastError   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Calendar HQ / Google Calendar (CampaignOS) ---

model CalendarSource {
  id                 String                   @id @default(cuid())
  /// Short machine label (kept for back-compat; prefer `displayName` in UI when set).
  label              String
  /// Staff-facing name (e.g. “Candidate — public appearances”).
  displayName        String?
  /// CampaignOS rail for routing outbound events (Slice 5).
  sourceType         CalendarSourceType       @default(INTERNAL_STAFF_PLANNING)
  /// When true, eligible as the *public* Google target for PUBLISHED + on-site events.
  isPublicFacing     Boolean                  @default(false)
  provider           CalendarProvider         @default(GOOGLE)
  /// Google `calendarId` (e.g. primary, or group calendar)
  externalCalendarId String
  color              String?
  visibility         CalendarSourceVisibility @default(STAFF)
  isActive           Boolean                  @default(true)
  syncEnabled        Boolean                  @default(true)
  /// Incremental list sync
  syncToken          String?                  @db.Text
  /// OAuth tokens (use env encryption in app layer for production)
  oauthJson          Json?                    @default("{}")
  lastFullSyncAt     DateTime?
  lastIncrementalAt  DateTime?
  ownerUserId        String?
  owner              User?                    @relation("CalendarSourceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  events        CampaignEvent[]
  watchChannels CalendarWatchChannel[]
  syncLogs      EventSyncLog[]         @relation("EventSyncBySource")

  @@index([sourceType, isActive, syncEnabled])
  @@index([isPublicFacing, isActive, syncEnabled])
}

model CalendarWatchChannel {
  id               String         @id @default(cuid())
  calendarSourceId String
  calendarSource   CalendarSource @relation(fields: [calendarSourceId], references: [id], onDelete: Cascade)
  channelId        String
  resourceId       String
  /// Google’s channel token
  token            String?
  expiration       DateTime
  lastRenewedAt    DateTime?
  lastError        String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([calendarSourceId, expiration])
  @@index([channelId])
}

/// Monday-start week; mission, outcomes, role commitments, and up to 5 big rocks
model WeeklyCampaignPlan {
  id                  String          @id @default(cuid())
  /// Inclusive start of week (00:00 local stored as DateTime, normalized in app to Monday)
  weekStart           DateTime        @unique
  missionStatement    String?         @db.Text
  outcome1            String?         @db.Text
  outcome2            String?         @db.Text
  outcome3            String?         @db.Text
  /// e.g. { "candidate", "field", "comms", ... } — free text per role key
  roleCommitmentsJson Json?           @default("{}")
  bigRocks            WeeklyBigRock[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([weekStart])
}

model WeeklyBigRock {
  id         String             @id @default(cuid())
  weekPlanId String
  weekPlan   WeeklyCampaignPlan @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  sortOrder  Int                @default(0)
  title      String
  notes      String?            @db.Text
  /// Optional link: times come from the event
  eventId    String?            @unique
  event      CampaignEvent?     @relation("BigRockEvent", fields: [eventId], references: [id], onDelete: SetNull)
  /// Synthetic block when not linked to an event
  startAt    DateTime?
  endAt      DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([weekPlanId, sortOrder])
}

model EventApproval {
  id                String             @id @default(cuid())
  eventId           String
  event             CampaignEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  round             Int                @default(1)
  state             EventApprovalState @default(PENDING)
  note              String?            @db.Text
  submittedByUserId String?
  submittedBy       User?              @relation("ApprovalSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  approverUserId    String?
  approver          User?              @relation("ApprovalDecidedBy", fields: [approverUserId], references: [id], onDelete: SetNull)
  decidedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([eventId, state])
  @@index([state, createdAt])
}

/// Append-only audit of workflow transitions (operational history).
model EventStageChangeLog {
  id          String              @id @default(cuid())
  eventId     String
  event       CampaignEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fromState   EventWorkflowState?
  toState     EventWorkflowState
  actorUserId String?
  actor       User?               @relation("EventStageChangeActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  /// Staff note on this transition (approval note, send-back reason, cancel reason ref, etc.).
  note        String?             @db.Text
  createdAt   DateTime            @default(now())

  @@index([eventId, createdAt])
  @@index([toState, createdAt])
}

model EventSyncLog {
  id               String             @id @default(cuid())
  eventId          String?
  event            CampaignEvent?     @relation("EventSyncForEvent", fields: [eventId], references: [id], onDelete: SetNull)
  calendarSourceId String?
  calendarSource   CalendarSource?    @relation("EventSyncBySource", fields: [calendarSourceId], references: [id], onDelete: SetNull)
  direction        EventSyncDirection
  status           EventSyncLogStatus
  message          String?            @db.Text
  detailJson       Json?              @default("{}")
  createdAt        DateTime           @default(now())

  @@index([eventId, createdAt])
  @@index([calendarSourceId, createdAt])
}

model EventAnalyticsSnapshot {
  id          String         @id @default(cuid())
  /// Calendar day in campaign TZ (date-only, UTC midnight is fine for aggregation)
  day         DateTime
  /// GLOBAL = whole campaign, EVENT = one event, COUNTY = county roll-up
  scope       String
  eventId     String?
  event       CampaignEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  countyId    String?
  county      County?        @relation(fields: [countyId], references: [id], onDelete: SetNull)
  metricsJson Json           @default("{}")
  createdAt   DateTime       @default(now())

  @@index([day, scope])
  @@index([countyId, day])
  @@index([eventId, day])
}

// --- External press / earned media monitoring (Arkansas outlets, Kelly Grappe) ---

enum ExternalMediaSourceType {
  NEWSPAPER
  NEWS_MAGAZINE
  DIGITAL_LOCAL
  TV
  RADIO
  BLOG
  OTHER
}

enum ExternalMediaMentionType {
  NEWS_ARTICLE
  EDITORIAL
  OPINION
  LETTER_TO_EDITOR
  TV_WEB_STORY
  CANDIDATE_LISTING
  EVENT_RECAP
  ENDORSEMENT
  OTHER
}

enum ExternalMediaReviewStatus {
  PENDING
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum ExternalMediaIngestMethod {
  RSS
  SITEMAP
  SEARCH_PAGE
  MANUAL_SEED
  HOMEPAGE_SECTION
  TAG_PAGE
  CATEGORY_PAGE
}

enum ExternalMediaMatchTier {
  DEFINITE
  LIKELY
  UNCERTAIN
  NOT_RELEVANT
}

/// Registry row synced from `src/lib/media-monitor/sources` seeds (editable in DB for overrides).
model ExternalMediaSource {
  id                String                  @id @default(cuid())
  slug              String                  @unique
  name              String
  sourceType        ExternalMediaSourceType
  region            String
  coveredCities     String[]                @default([])
  homepage          String
  priority          Int                     @default(5)
  rssUrl            String?
  sitemapUrl        String?
  searchUrlTemplate String?                 @db.Text
  discoveryMethods  String[]                @default([])
  notes             String?                 @db.Text
  isActive          Boolean                 @default(true)
  lastFetchedAt     DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  mentions ExternalMediaMention[]

  @@index([isActive, priority])
}

model ExternalMediaMention {
  id           String                  @id @default(cuid())
  sourceId     String
  source       ExternalMediaSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  /// Denormalized for exports and UI when source row changes.
  sourceName   String
  sourceType   ExternalMediaSourceType
  sourceRegion String?
  cityCoverage String[]                @default([])

  title        String
  url          String
  canonicalUrl String
  /// Stable dedupe: normalized URL hash + optional title/date fingerprint.
  dedupeKey    String @unique

  publishedAt       DateTime?
  author            String?
  section           String?
  summary           String?   @db.Text
  fullText          String?   @db.Text
  transcriptText    String?   @db.Text
  transcriptMissing Boolean   @default(false)

  mentionType       ExternalMediaMentionType @default(NEWS_ARTICLE)
  confidenceScore   Float?
  matchTier         ExternalMediaMatchTier
  matchedEntityName String                   @default("Kelly Grappe")
  matchedPersonName String?
  isOpinion         Boolean                  @default(false)
  isEditorial       Boolean                  @default(false)
  sentimentHint     String?

  ingestionMethod ExternalMediaIngestMethod
  discoveredAt    DateTime                  @default(now())
  lastCheckedAt   DateTime                  @updatedAt

  reviewStatus                  ExternalMediaReviewStatus @default(PENDING)
  campaignSummary               String?                   @db.Text
  markForSocialShare            Boolean                   @default(false)
  markForEmailRoundup           Boolean                   @default(false)
  markForSurrogateAmplification Boolean                   @default(false)
  responseNeeded                Boolean                   @default(false)
  needsAmplification            Boolean                   @default(false)
  showOnPublicSite              Boolean                   @default(false)

  relatedEventId  String?
  relatedEvent    CampaignEvent? @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)
  relatedCountyId String?
  relatedCounty   County?        @relation(fields: [relatedCountyId], references: [id], onDelete: SetNull)

  openAiRefined Boolean @default(false)
  rawPayload    Json?

  @@index([sourceId, publishedAt])
  @@index([reviewStatus, publishedAt])
  @@index([matchTier, publishedAt])
  @@index([showOnPublicSite, publishedAt])
  @@index([relatedCountyId])
  @@index([relatedEventId])
}

model ExternalMediaIngestRun {
  id               String    @id @default(cuid())
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  label            String?
  dryRun           Boolean   @default(false)
  sourceSlug       String?
  incrementalSince DateTime?
  summaryJson      Json?
  itemsDiscovered  Int       @default(0)
  itemsInserted    Int       @default(0)
  itemsUpdated     Int       @default(0)
  errorsJson       Json?
  error            String?   @db.Text

  @@index([startedAt])
}

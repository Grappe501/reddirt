{
  "name": "reddirt-site",
  "version": "0.8.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:db": "docker compose up -d",
    "dev:prepare": "prisma generate && prisma migrate deploy",
    "dev:full": "node scripts/launch-dev.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:all": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint:all && npm run typecheck && npm run build",
    "harden": "npm run check",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "ingest": "tsx scripts/ingest-docs.ts",
    "ingest:interactive": "node scripts/ingest-prompt-key.cjs",
    "ingest:watch": "tsx scripts/campaign-media-ingest-watcher.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.104.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "framer-motion": "^11.18.2",
    "next": "^15.1.6",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.13.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }

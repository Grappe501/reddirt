# =============================================================================
# Environment template — copy to `.env` (and optionally `.env.local` for overrides).
# Never commit real secrets. `.env` and `.env.local` are gitignored.
#
# Load order: `.env` → `.env.local` (later wins). Prisma CLI reads `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE — required for Prisma, admin board, forms, ingest
# -----------------------------------------------------------------------------
# Local Docker default (see docker-compose.yml — host port 5433):
DATABASE_URL="postgresql://reddirt:reddirt@127.0.0.1:5433/reddirt"
#
# Production / hosted Postgres: use your provider’s connection string (SSL params as required).

# -----------------------------------------------------------------------------
# ADMIN — content board at /admin (required in production)
# -----------------------------------------------------------------------------
ADMIN_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# OPENAI — server-only (optional for static browsing; required for ingest + RAG search + intake)
# Interactive ingest: npm run ingest:interactive
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# PUBLIC — NEXT_PUBLIC_* is embedded in client bundles. No secrets here.
# -----------------------------------------------------------------------------
# Canonical URL for Open Graph / metadata (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://www.kellygrappe.com

# Donation — overrides GoodChange default from KellyGrappe.com
# NEXT_PUBLIC_DONATE_EXTERNAL_URL=https://goodchange.app/donate/...

# Legacy public site + Substack (volunteer/join + journal)
# NEXT_PUBLIC_LEGACY_SITE_URL=https://www.kellygrappe.com
# NEXT_PUBLIC_JOIN_CAMPAIGN_URL=https://www.kellygrappe.com
# NEXT_PUBLIC_CAMPAIGN_BLOG_URL=https://kellygrappesos.substack.com
# NEXT_PUBLIC_CONTACT_EMAIL=kelly@kellygrappe.com

# Official Arkansas voter registration lookup (VoterView / SOS). County pages and voter CTAs link here — no substitute.
# NEXT_PUBLIC_AR_VOTER_LOOKUP_URL=https://www.voterview.ar-nova.org/voterview
#
# Voter center UI: `handoff` (default) = native page + new tab to official tool. `campaign_assist_only` = emphasize campaign file help.
# NEXT_PUBLIC_VOTER_LOOKUP_UI_MODE=handoff

# Campaign registration metrics baseline (YYYY-MM-DD or full ISO). Central source: `src/config/campaign-registration-baseline.ts`
# CAMPAIGN_REGISTRATION_BASELINE=2025-11-25
# NEXT_PUBLIC_CAMPAIGN_REGISTRATION_BASELINE=2025-11-25

# “Paid for by” link target (defaults to NEXT_PUBLIC_SITE_URL). e.g. main campaign / RedDirt public site.
# NEXT_PUBLIC_COMMITTEE_SITE_URL=https://www.kellygrappe.com

# Optional homepage media
# NEXT_PUBLIC_HERO_VIDEO_URL=/media/hero-loop.mp4
# NEXT_PUBLIC_FEATURE_VIDEO_EMBED_URL=https://www.youtube.com/embed/VIDEO_ID

# -----------------------------------------------------------------------------
# FEEDS & SOCIAL — server-only; used by admin / orchestrator sync (optional)
# -----------------------------------------------------------------------------
# SUBSTACK_FEED_URL=https://yourhandle.substack.com/feed
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=
# INSTAGRAM_ACCESS_TOKEN=
# YOUTUBE_CHANNEL_ID=
# YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# CAMPAIGN-OWNED MEDIA — local disk by default (`data/owned-campaign-media` under project root)
# -----------------------------------------------------------------------------
# Override absolute root for uploads (optional; defaults to ./data/owned-campaign-media)
# OWNED_MEDIA_DATA_ROOT=H:/SOSWebsite/RedDirt/data/owned-campaign-media
# Max upload size in bytes (default 500MB; must be <= serverActions.bodySizeLimit in next.config.ts)
# OWNED_MEDIA_MAX_BYTES=524288000
# Reverse geocoding: OpenStreetMap Nominatim (1 req/s politeness; set 0 to disable network on ingest)
# OWNED_MEDIA_NOMINATIM=1
# OWNED_MEDIA_NOMINATIM_UA=MyCampaign/1.0 (contact: you@example.com)

# -----------------------------------------------------------------------------
# Supabase — required for `npm run ingest:watch` (folder → Storage + `OwnedMediaAsset`)
# Create a public (or use signed-URL) bucket matching SUPABASE_CAMPAIGN_MEDIA_BUCKET.
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY= (server/ingest only — never in NEXT_PUBLIC)
# Optional bucket name (default: campaign-media)
# SUPABASE_CAMPAIGN_MEDIA_BUCKET=campaign-media
# Watch folder: ./campaign-media/uploads (override)
# CAMPAIGN_MEDIA_ROOT=H:/SOSWebsite/RedDirt/campaign-media
# CAMPAIGN_MEDIA_WATCH_DIR=H:/SOSWebsite/RedDirt/campaign-media/uploads
# On start, scan existing files in uploads (set 0 to only watch new adds)
# CAMPAIGN_MEDIA_INGEST_SCAN_ON_START=1
#
# FUTURE — public site Supabase (not wired) — if you add @supabase/ssr:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# FUTURE — Email / SMS (not referenced by RedDirt today; keep if you add notifications)
# -----------------------------------------------------------------------------
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# FUTURE — Deploy & tooling (optional)
# -----------------------------------------------------------------------------
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
# GITHUB_PAT=

# -----------------------------------------------------------------------------

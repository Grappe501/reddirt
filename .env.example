# =============================================================================
# Environment template — copy to `.env` (and optionally `.env.local` for overrides).
# Never commit real secrets. `.env` and `.env.local` are gitignored.
#
# Load order: `.env` → `.env.local` (later wins). Prisma CLI reads `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE — required for Prisma, admin board, forms, ingest
# -----------------------------------------------------------------------------
# Local Docker default (see docker-compose.yml — host port 5433):
DATABASE_URL="postgresql://reddirt:reddirt@127.0.0.1:5433/reddirt"
#
# Bring up DB + run migrations:  npm run stack:up
# Quick check (container must be running):  npm run db:ping
# Avoid `npx prisma db pull` for “is it up?” — it re-introspects the whole schema and can look hung.
#
# Production / hosted Postgres: use your provider’s connection string (SSL params as required).

# -----------------------------------------------------------------------------
# ADMIN — content board at /admin (required in production)
# -----------------------------------------------------------------------------
ADMIN_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# OPENAI — server-only (optional for static browsing; required for ingest + RAG search + intake)
# Interactive ingest: npm run ingest:interactive
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Campaign guide (/api/assistant) — optional public-facing links for tools
# -----------------------------------------------------------------------------
# Newsletter signup URL surfaced by get_public_contact_info (e.g. Mailchimp/ActionKit). Not a secret.
# CAMPAIGN_NEWSLETTER_SIGNUP_URL=https://example.com/newsletter
# Dedicated press inbox (defaults to general campaign email in prompts if unset)
# CAMPAIGN_PRESS_EMAIL=press@example.com

# -----------------------------------------------------------------------------
# PUBLIC — NEXT_PUBLIC_* is embedded in client bundles. No secrets here.
# -----------------------------------------------------------------------------
# Canonical URL for Open Graph / metadata (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://www.kellygrappe.com

# Donation — overrides GoodChange default from KellyGrappe.com
# NEXT_PUBLIC_DONATE_EXTERNAL_URL=https://goodchange.app/donate/...

# County coordination hub (sister app — separate Netlify deploy; Pope-first portal)
# NEXT_PUBLIC_COUNTY_WORKBENCH_URL=https://your-county-workbench.netlify.app

# Legacy public site (volunteer/join + cross-links)
# NEXT_PUBLIC_LEGACY_SITE_URL=https://www.kellygrappe.com
# Optional. Defaults to on-site volunteer form: /get-involved#volunteer
# NEXT_PUBLIC_JOIN_CAMPAIGN_URL=https://www.example.com/volunteer
# NEXT_PUBLIC_VOLUNTEER_SIGNUP_URL=/get-involved#volunteer
# NEXT_PUBLIC_CONTACT_EMAIL=kelly@kellygrappe.com

# -----------------------------------------------------------------------------
# /from-the-road + footer — public social hub (NEXT_PUBLIC_* only; no secrets)
# Same keys power the footer icons and the channel grid on /from-the-road.
# -----------------------------------------------------------------------------
# Substack / notebook (footer “Substack” icon uses this too):
# NEXT_PUBLIC_CAMPAIGN_BLOG_URL=https://kellygrappesos.substack.com
#
# Official channel URLs:
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://www.facebook.com/Kelly-Grappe-SOS
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/KellyGrappeSOS/
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/kellygrappesos
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://www.youtube.com/@kellygrappesos
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL=https://www.tiktok.com/@kellygrappesos
#
# Optional live embeds on /from-the-road (official iframes only):
# NEXT_PUBLIC_FTR_FACEBOOK_PAGE_URL=   # Page plugin href; defaults to NEXT_PUBLIC_SOCIAL_FACEBOOK_URL
# NEXT_PUBLIC_FTR_TIKTOK_VIDEO_IDS=7123456789012345678,7123456789012345679
# NEXT_PUBLIC_FTR_YOUTUBE_UPLOADS_PLAYLIST_ID=UUxxxxxxxx   # YouTube Studio → Uploads playlist id (often starts with UU)
# NEXT_PUBLIC_FTR_INSTAGRAM_EMBED_SHORTCODES=AbCdEfGhIjK,xyz_12a   # Shortcodes from https://www.instagram.com/p/SHORTCODE/

# About page: Talk Business & Politics — paste the iframe `src` from their embed code (https only).
# NEXT_PUBLIC_TALK_BUSINESS_IFRAME_SRC=https://www.youtube.com/embed/xxxxxxxxxxx
# Optional accessible title for that iframe:
# NEXT_PUBLIC_TALK_BUSINESS_IFRAME_TITLE=Kelly Grappe — Talk Business & Politics
# If you omit the iframe URL, set the 11-character YouTube id (becomes youtube-nocookie embed):
# NEXT_PUBLIC_TALK_BUSINESS_KELLY_YOUTUBE_VIDEO_ID=
# Or set a generic site embed URL (must be /embed/...); also used as fallback for this block:
# NEXT_PUBLIC_FEATURE_VIDEO_EMBED_URL=https://www.youtube.com/embed/VIDEO_ID
# If all are unset, /about uses the Admin featured / inbound YouTube id when the DB has one.

# Official Arkansas voter registration lookup (VoterView / SOS). County pages and voter CTAs link here — no substitute.
# NEXT_PUBLIC_AR_VOTER_LOOKUP_URL=https://www.voterview.ar-nova.org/voterview
#
# Voter center UI: `handoff` (default) = native page + new tab to official tool. `campaign_assist_only` = emphasize campaign file help.
# NEXT_PUBLIC_VOTER_LOOKUP_UI_MODE=handoff

# Campaign registration metrics baseline (YYYY-MM-DD or full ISO). Central source: `src/config/campaign-registration-baseline.ts`
# CAMPAIGN_REGISTRATION_BASELINE=2025-11-25
# NEXT_PUBLIC_CAMPAIGN_REGISTRATION_BASELINE=2025-11-25

# “Paid for by” link target (defaults to NEXT_PUBLIC_SITE_URL). e.g. main campaign / RedDirt public site.
# NEXT_PUBLIC_COMMITTEE_SITE_URL=https://www.kellygrappe.com

# Optional homepage media
# NEXT_PUBLIC_HERO_VIDEO_URL=/media/hero-loop.mp4
# (NEXT_PUBLIC_FEATURE_VIDEO_EMBED_URL is documented above with Talk Business — same key.)

# -----------------------------------------------------------------------------
# FEEDS & SOCIAL — server-only; used by admin / orchestrator sync (optional)
# -----------------------------------------------------------------------------
# SUBSTACK_FEED_URL=https://yourhandle.substack.com/feed
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=
# INSTAGRAM_ACCESS_TOKEN=
# YOUTUBE_CHANNEL_ID=
# YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# CAMPAIGN-OWNED MEDIA — local disk by default (`data/owned-campaign-media` under project root)
# -----------------------------------------------------------------------------
# Override absolute root for uploads (optional; defaults to ./data/owned-campaign-media)
# OWNED_MEDIA_DATA_ROOT=H:/SOSWebsite/RedDirt/data/owned-campaign-media
# Max upload size in bytes (default 2GiB; hard cap 4GiB; must stay <= serverActions body limit in next.config.ts)
# OWNED_MEDIA_MAX_BYTES=2147483648
# Reverse geocoding: OpenStreetMap Nominatim (1 req/s politeness; set 0 to disable network on ingest)
# OWNED_MEDIA_NOMINATIM=1
# OWNED_MEDIA_NOMINATIM_UA=MyCampaign/1.0 (contact: you@example.com)

# -----------------------------------------------------------------------------
# Supabase — required for `npm run ingest:watch` (folder → Storage + `OwnedMediaAsset`)
# Create a public (or use signed-URL) bucket matching SUPABASE_CAMPAIGN_MEDIA_BUCKET.
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY= (server/ingest only — never in NEXT_PUBLIC)
# Optional bucket name (default: campaign-media)
# SUPABASE_CAMPAIGN_MEDIA_BUCKET=campaign-media
# Watch folder: ./campaign-media/uploads (override)
# CAMPAIGN_MEDIA_ROOT=H:/SOSWebsite/RedDirt/campaign-media
# CAMPAIGN_MEDIA_WATCH_DIR=H:/SOSWebsite/RedDirt/campaign-media/uploads
# On start, scan existing files in uploads (set 0 to only watch new adds)
# CAMPAIGN_MEDIA_INGEST_SCAN_ON_START=1
#
# FUTURE — public site Supabase (not wired) — if you add @supabase/ssr:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Google Calendar (Campaign HQ) — OAuth for `CalendarSource`; optional public site URL for callback
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=https://your-domain.com/api/calendar/google/callback
# Webhook for push sync (must be HTTPS in production): same origin + /api/calendar/google/webhook
# Cron: GET /api/calendar/google/cron-sync?key=... (incremental ingest + watch renewal)
# CALENDAR_CRON_SECRET=
# Mark the campaign Google calendar `CalendarSource` as isPublicFacing in DB (seed/admin), complete OAuth
# on /admin/workbench/calendar, then set true so new events from that calendar go live without a draft step:
# GOOGLE_CALENDAR_AUTO_PUBLISH_PUBLIC_FACING=true
# GET /api/cron/comms-broadcasts?key=... (broadcast campaign batches)
# COMMS_BROADCAST_CRON_SECRET=

# Community fairs/festivals ingest → Prisma `ArkansasFestivalIngest` → /from-the-road feed
# GET /api/cron/festivals-ingest?key=...  |  GET /api/cron/festivals-coverage?key=... (AI weekend plan)
# FESTIVAL_INGEST_CRON_SECRET=   # falls back to CALENDAR_CRON_SECRET if unset
# FESTIVAL_INGEST_SEED_JSON=      # optional dev: JSON array of { name, startAt, endAt, sourceUrl, city?, countyId? }

# Earned media / press monitor (RSS-first; respects robots.txt)
# GET /api/cron/media-monitor?key=...&incremental=1  (optional &full=1 for all registry sources with feeds)
# MEDIA_MONITOR_CRON_SECRET=   # falls back to CALENDAR_CRON_SECRET if unset
# MEDIA_MONITOR_USE_OPENAI=1    # optional: refine uncertain items (uses OPENAI_API_KEY)

# -----------------------------------------------------------------------------
# Email / SMS (workbench, webhooks) — set as needed
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=
# PEM from SendGrid → Mail → Event Webhook (enable signed), required in production
# SENDGRID_WEBHOOK_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
# TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# FUTURE — Deploy & tooling (optional)
# -----------------------------------------------------------------------------
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
# GITHUB_PAT=

# -----------------------------------------------------------------------------
# Maps, civic data, news APIs (optional)
# -----------------------------------------------------------------------------
# GOOGLE_API_KEY=
# Public /events map uses OpenStreetMap + Leaflet (no key). Google keys are optional for other features.
# GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# OPENCAGE_API_KEY=
# API_DOT_GOV_KEY=
# OPENSTATES_API_KEY=
# CONGRESS_GOV_API_KEY=
# OPENFEC_API_KEY=
# SOCRATA_APP_TOKEN=
# FOURSQUARE_API_KEY=
# NEWSAPI_API_KEY=
# GUARDIAN_API_KEY=
# GOOGLE_CIVIC_API_KEY=
# NPPES_NPI_API_BASE=https://npiregistry.cms.hhs.gov/api/
# TIGER_GEOCODER_BASE=https://geocoding.geo.census.gov/
